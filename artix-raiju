#!/usr/bin/env bash
# Artix Installation Script (Raiju Preset) — vibecoded by Claude Code
# Run as root from the Artix base ISO (dinit variant recommended)

set -euo pipefail

MOUNT_ROOT="/mnt"
BACKTITLE="Artix Installer  |  Raiju Preset  |  vibecoded by Claude Code"
TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

# ─── Sanity checks ────────────────────────────────────────────────────────────
if [[ $EUID -ne 0 ]]; then echo "Run as root."; exit 1; fi
command -v dialog    &>/dev/null || pacman -Sy --noconfirm dialog
command -v parted    &>/dev/null || { echo "parted is required."; exit 1; }
command -v basestrap &>/dev/null || { echo "basestrap is required — boot from an Artix ISO."; exit 1; }

# ─── TUI helpers ──────────────────────────────────────────────────────────────
_DIALOG_EXIT=0
d()        { _DIALOG_EXIT=0; dialog --backtitle "$BACKTITLE" "$@" 2>"$TMP" || _DIALOG_EXIT=$?; }
result()   { cat "$TMP"; }
dialog_ok(){ [[ $_DIALOG_EXIT -eq 0 ]]; }
die()      { dialog --backtitle "$BACKTITLE" --title "Fatal Error" --msgbox "$*" 8 60; exit 1; }
info_box() { dialog --backtitle "$BACKTITLE" --title "Installing..." --infobox "$*" 5 60; }

# ─── Timezone picker ──────────────────────────────────────────────────────────
pick_timezone() {
    local zoneroot="/usr/share/zoneinfo"
    local region_args=()
    while IFS= read -r r; do
        region_args+=("$r" "")
    done < <(ls "$zoneroot" | grep -E '^[A-Z]' | grep -v '^posix$' | grep -v '^right$' | sort)

    d --title "Timezone — Region" --menu "Select your region:" 24 50 16 "${region_args[@]}"
    local region; region=$(result)
    if [[ -z "$region" ]]; then TIMEZONE="UTC"; return; fi

    if [[ -d "$zoneroot/$region" ]]; then
        local city_args=()
        while IFS= read -r c; do
            city_args+=("$c" "")
        done < <(find "$zoneroot/$region" -type f | sed "s|$zoneroot/$region/||" | sort)

        d --title "Timezone — $region" --menu "Select your city:" 24 56 16 "${city_args[@]}"
        local city; city=$(result)
        if [[ -z "$city" ]]; then TIMEZONE="UTC"; return; fi
        TIMEZONE="$region/$city"
    else
        TIMEZONE="$region"
    fi
}

# ─── Config collection ────────────────────────────────────────────────────────
collect_config() {
    d --title "Artix Installer — Raiju Preset" --msgbox \
"Artix Linux Installer — Raiju Preset

Preset (fixed):
  Init:        dinit
  Filesystem:  btrfs  (@  @home  @snapshots  @var_log)
  Shell:       Noctalia Shell
  Audio:       PipeWire + WirePlumber (user service via turnstile)
  Greeter:     sddm
  Bootloader:  GRUB (UEFI)
  AUR helper:  yay

Installed apps:
  neovim (vim alias)  firefox  vesktop  steam
  ripgrep  fd  git  lazygit  nodejs  alacritty
  Iosevka Nerd Font  JetBrainsMono Nerd Font

You choose: disk, compositor, timezone, hostname, username, passwords." 26 62

    # ── Disk ──
    local disk_args=()
    while IFS= read -r line; do
        local name size model
        name=$(awk '{print $1}' <<< "$line")
        size=$(awk '{print $2}' <<< "$line")
        model=$(awk '{$1=$2=""; print $0}' <<< "$line" | xargs)
        disk_args+=("/dev/$name" "$size  $model")
    done < <(lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -v loop)
    [[ ${#disk_args[@]} -eq 0 ]] && die "No block devices found."

    d --title "Target Disk" \
      --menu "Select the disk to install Artix on.\nWARNING: it will be completely wiped." \
      18 70 8 "${disk_args[@]}"
    DISK=$(result)
    [[ -b "$DISK" ]] || die "No disk selected."

    d --title "Confirm Wipe" --yesno \
"ALL DATA on $DISK will be permanently destroyed.\n\nAre you sure?" 8 55
    dialog_ok || exit 0

    # ── Compositor ──
    d --title "Compositor" --menu "Choose your Wayland compositor:" 10 60 2 \
        "niri"    "niri — scrollable tiling (recommended)" \
        "mangowm" "mangowm — minimalist dwl-based (AUR)"
    COMPOSITOR=$(result)
    [[ -z "$COMPOSITOR" ]] && COMPOSITOR="niri"

    # ── Timezone ──
    pick_timezone

    # ── Hostname ──
    d --title "Hostname" --inputbox "Enter hostname:" 8 50 "raiju"
    HOSTNAME=$(result); [[ -n "$HOSTNAME" ]] || HOSTNAME="raiju"

    # ── Username ──
    d --title "Username" --inputbox "Enter username:" 8 50 "raiju"
    USERNAME=$(result); [[ -n "$USERNAME" ]] || USERNAME="raiju"

    # ── Root password ──
    local rpw1 rpw2
    d --title "Root Password" --passwordbox "Enter root password:" 8 50; rpw1=$(result)
    d --title "Root Password" --passwordbox "Confirm root password:" 8 50; rpw2=$(result)
    [[ "$rpw1" == "$rpw2" ]] || die "Root passwords do not match."
    [[ -n "$rpw1" ]]          || die "Root password cannot be empty."
    ROOT_PASSWORD="$rpw1"

    # ── User password ──
    local upw1 upw2
    d --title "User Password" --passwordbox "Enter password for $USERNAME:" 8 50; upw1=$(result)
    d --title "User Password" --passwordbox "Confirm password for $USERNAME:" 8 50; upw2=$(result)
    [[ "$upw1" == "$upw2" ]] || die "User passwords do not match."
    [[ -n "$upw1" ]]          || die "User password cannot be empty."
    USER_PASSWORD="$upw1"

    # ── Summary ──
    d --title "Confirm Installation" --yesno \
"Artix Raiju Preset — Summary
──────────────────────────────────────
  Disk:        $DISK
  Compositor:  $COMPOSITOR + Noctalia Shell
  Audio:       PipeWire (user service via turnstile)
  Init:        dinit
  Filesystem:  btrfs
  Bootloader:  GRUB (UEFI)
  Timezone:    $TIMEZONE
  Hostname:    $HOSTNAME
  Username:    $USERNAME
──────────────────────────────────────
  ALL DATA ON $DISK WILL BE DESTROYED.

Proceed with installation?" 24 52
    dialog_ok || exit 0
}

# ─── Phase 0: WiFi ────────────────────────────────────────────────────────────
phase_wifi() {
    if curl -s --max-time 5 https://artixlinux.org >/dev/null 2>&1; then
        return 0
    fi

    d --title "Network" --yesno \
"No internet connection detected.

Do you want to connect to a WiFi network?" 8 52
    dialog_ok || return 0

    local iface_list=()
    while IFS= read -r i; do
        iface_list+=("$i" "")
    done < <(iw dev 2>/dev/null | awk '/Interface/{print $2}' || true)

    if [[ ${#iface_list[@]} -eq 0 ]]; then
        d --title "WiFi" --msgbox "No wireless interface found.\nConnect via ethernet and re-run." 8 56
        return 0
    fi

    local iface
    if [[ ${#iface_list[@]} -eq 2 ]]; then
        iface="${iface_list[0]}"
    else
        d --title "WiFi — Interface" --menu "Select your wireless interface:" 12 50 6 "${iface_list[@]}"
        iface=$(result)
    fi
    [[ -z "$iface" ]] && return 0

    info_box "Scanning for WiFi networks on $iface..."
    ip link set "$iface" up 2>/dev/null || true
    local scan_out
    scan_out=$(iw dev "$iface" scan 2>/dev/null | grep 'SSID:' | sed 's/.*SSID: //' | grep -v '^$' | sort -u || true)

    local ssid=""
    if [[ -n "$scan_out" ]]; then
        local ssid_args=()
        while IFS= read -r s; do
            ssid_args+=("$s" "")
        done <<< "$scan_out"
        ssid_args+=("__manual__" "Enter SSID manually")
        d --title "WiFi — Select Network" --menu "Choose a network:" 20 60 12 "${ssid_args[@]}"
        ssid=$(result)
    fi

    if [[ -z "$ssid" || "$ssid" == "__manual__" ]]; then
        d --title "WiFi — SSID" --inputbox "Enter WiFi network name (SSID):" 8 54 ""
        ssid=$(result)
    fi
    [[ -z "$ssid" ]] && return 0

    d --title "WiFi — Password" --passwordbox "Enter password for \"$ssid\":" 8 54
    local psk; psk=$(result)

    info_box "Connecting to $ssid..."
    local wpa_conf; wpa_conf=$(mktemp)
    wpa_passphrase "$ssid" "$psk" > "$wpa_conf"
    pkill wpa_supplicant 2>/dev/null || true
    sleep 1
    wpa_supplicant -B -i "$iface" -c "$wpa_conf" -P /tmp/wpa.pid >/dev/null 2>&1
    rm -f "$wpa_conf"
    dhcpcd "$iface" -t 15 -q 2>/dev/null || dhclient "$iface" 2>/dev/null || true

    if curl -s --max-time 10 https://artixlinux.org >/dev/null 2>&1; then
        d --title "WiFi" --msgbox "Connected to $ssid successfully." 6 48
    else
        d --title "WiFi" --msgbox "Could not verify connection.\nProceeding anyway." 8 52
    fi
}

# ─── Phase 1: Disk ────────────────────────────────────────────────────────────
phase_disk() {
    info_box "Unmounting any existing mounts on $DISK..."
    swapoff -a 2>/dev/null || true
    umount -R "$MOUNT_ROOT" 2>/dev/null || true
    for part in $(lsblk -lno NAME "$DISK" | tail -n +2); do
        umount -l "/dev/$part" 2>/dev/null || true
    done

    [[ "$DISK" =~ nvme ]] && PART_PREFIX="${DISK}p" || PART_PREFIX="${DISK}"

    info_box "Partitioning $DISK (GPT — EFI + btrfs root)..."
    parted -s "$DISK" \
        mklabel gpt \
        mkpart ESP fat32 1MiB 513MiB \
        set 1 esp on \
        mkpart root btrfs 513MiB 100%

    PART_EFI="${PART_PREFIX}1"
    PART_ROOT="${PART_PREFIX}2"

    info_box "Formatting partitions..."
    mkfs.fat -F32 -n EFI "$PART_EFI"
    mkfs.btrfs -f -L artix "$PART_ROOT"

    info_box "Creating btrfs subvolumes..."
    mount "$PART_ROOT" "$MOUNT_ROOT"
    btrfs subvolume create "$MOUNT_ROOT/@"
    btrfs subvolume create "$MOUNT_ROOT/@home"
    btrfs subvolume create "$MOUNT_ROOT/@snapshots"
    btrfs subvolume create "$MOUNT_ROOT/@var_log"
    umount "$MOUNT_ROOT"

    local btrfs_opts="noatime,compress=zstd:1,space_cache=v2"
    info_box "Mounting btrfs subvolumes..."
    mount -o "${btrfs_opts},subvol=@"          "$PART_ROOT" "$MOUNT_ROOT"
    mkdir -p "$MOUNT_ROOT"/{home,.snapshots,var/log,boot/efi}
    mount -o "${btrfs_opts},subvol=@home"      "$PART_ROOT" "$MOUNT_ROOT/home"
    mount -o "${btrfs_opts},subvol=@snapshots" "$PART_ROOT" "$MOUNT_ROOT/.snapshots"
    mount -o "${btrfs_opts},subvol=@var_log"   "$PART_ROOT" "$MOUNT_ROOT/var/log"
    mount "$PART_EFI" "$MOUNT_ROOT/boot/efi"
}

# ─── Phase 2: Basestrap ───────────────────────────────────────────────────────
phase_basestrap() {
    info_box "Installing base system with basestrap...\n(this may take several minutes)"

    basestrap "$MOUNT_ROOT" \
        base base-devel \
        dinit elogind-dinit \
        linux linux-headers linux-firmware \
        btrfs-progs \
        grub efibootmgr os-prober \
        networkmanager networkmanager-dinit \
        dbus dbus-dinit \
        seatd seatd-dinit \
        turnstile turnstile-dinit \
        pipewire wireplumber pipewire-alsa pipewire-jack pipewire-pulse \
        sddm sddm-dinit \
        git curl wget \
        neovim \
        ripgrep fd nodejs python \
        noto-fonts noto-fonts-emoji \
        sudo man-db man-pages \
        htop \
        bash-completion zsh fish \
        dialog wpa_supplicant dhcpcd \
        brightnessctl \
        grim slurp wl-clipboard \
        xdg-desktop-portal xdg-user-dirs \
        alacritty

    if [[ "$COMPOSITOR" == "niri" ]]; then
        basestrap "$MOUNT_ROOT" niri xdg-desktop-portal-gtk
    fi

    info_box "Generating fstab..."
    fstabgen -U "$MOUNT_ROOT" >> "$MOUNT_ROOT/etc/fstab"
}

