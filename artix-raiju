# ─── Phase 4: Chroot ──────────────────────────────────────────────────────────
phase_chroot() {
    cp --dereference /etc/resolv.conf "$MOUNT_ROOT/etc/"

    cat > "$MOUNT_ROOT/setup-chroot.sh" <<'CHROOT_SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
trap 'echo "[chroot] FAILED at line $LINENO: $BASH_COMMAND" >&2' ERR

# ── Locale / timezone / hostname ─────────────────────────────────────────────
echo "[chroot] Setting timezone..."
ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime
hwclock --systohc

echo "[chroot] Setting locale..."
sed -i 's/^#en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf

echo "[chroot] Setting hostname..."
echo "${HOSTNAME}" > /etc/hostname
cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   ${HOSTNAME}.localdomain ${HOSTNAME}
HOSTS

# ── Pacman repos ─────────────────────────────────────────────────────────────
echo "[chroot] Adding world-gremlins + Arch repos to pacman..."
cat >> /etc/pacman.conf <<'PACCONF'

# Artix staging — needed for pipewire-dinit / wireplumber-dinit
[world-gremlins]
Include = /etc/pacman.d/mirrorlist

# Arch Linux universe bridge (provides artix-archlinux-support pkg)
[universe]
Server = https://universe.artixlinux.org/$arch
Server = https://mirror1.artixlinux.org/universe/$arch

# Arch repos — firefox, steam, fonts, etc.
[extra]
Include = /etc/pacman.d/mirrorlist-arch

[multilib]
Include = /etc/pacman.d/mirrorlist-arch
PACCONF

# Generate an Arch mirrorlist (US HTTPS mirrors)
curl -s "https://archlinux.org/mirrorlist/?country=US&protocol=https&use_mirror_status=on" \
    | sed 's/^#Server/Server/' > /etc/pacman.d/mirrorlist-arch

pacman -Sy --noconfirm artix-archlinux-support
pacman-key --populate archlinux
pacman -Sy --noconfirm

# ── Extra packages from Arch/Artix repos ─────────────────────────────────────
echo "[chroot] Installing extra packages..."
pacman -S --noconfirm --needed \
    firefox \
    ttf-iosevka-nerd \
    ttf-jetbrains-mono-nerd \
    python-pynvim \
    lazygit \
    fastfetch \
    btop \
    cliphist \
    python-pywal

echo "[chroot] Installing Steam..."
pacman -S --noconfirm --needed steam \
    || echo "[warn] Steam failed to install (likely missing lib32 GPU deps) — install manually post-boot: pacman -S steam"

# pipewire-dinit and wireplumber-dinit (from world-gremlins)
echo "[chroot] Installing PipeWire dinit service files..."
pacman -S --noconfirm --needed pipewire-dinit wireplumber-dinit \
    || echo "[warn] pipewire-dinit/wireplumber-dinit not found — PipeWire user services must be enabled manually post-boot"

# ── GRUB ─────────────────────────────────────────────────────────────────────
echo "[chroot] Installing GRUB (UEFI)..."
grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Artix --recheck
grub-mkconfig -o /boot/grub/grub.cfg

# ── System dinit services ─────────────────────────────────────────────────────
echo "[chroot] Enabling system dinit services..."
mkdir -p /etc/dinit.d/boot.d
for svc in dbus elogind NetworkManager seatd turnstiled sddm; do
    if [[ -f /etc/dinit.d/${svc} ]]; then
        ln -sf /etc/dinit.d/${svc} /etc/dinit.d/boot.d/${svc}
        echo "  enabled: ${svc}"
    else
        echo "  [warn] service file not found: ${svc}"
    fi
done

# ── User account ─────────────────────────────────────────────────────────────
echo "[chroot] Setting root password..."
echo "root:${ROOT_PASSWORD}" | chpasswd

echo "[chroot] Creating user ${USERNAME}..."
useradd -m -G wheel,audio,video,input,seat -s /usr/bin/fish "${USERNAME}"
echo "${USERNAME}:${USER_PASSWORD}" | chpasswd

echo "[chroot] Configuring sudo..."
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# ── vim alias ────────────────────────────────────────────────────────────────
echo "[chroot] Setting vim alias (system-wide)..."
cat > /etc/profile.d/vim-alias.sh <<'VIMALIAS'
alias vim='nvim'
alias vi='nvim'
VIMALIAS
chmod 644 /etc/profile.d/vim-alias.sh
# Also cover non-login interactive shells (terminal emulators)
grep -qF "alias vim=" /etc/bash.bashrc || echo -e "\nalias vim='nvim'\nalias vi='nvim'" >> /etc/bash.bashrc
# Fish shell — system-wide vim alias
mkdir -p /etc/fish/conf.d
cat > /etc/fish/conf.d/vim-alias.fish <<'FISHALIAS'
alias vim='nvim'
alias vi='nvim'
FISHALIAS

# ── PipeWire user services ────────────────────────────────────────────────────
# turnstile starts a per-user dinit instance on login.
# Pre-create the user's boot.d symlinks so pipewire+wireplumber
# start automatically on first login.
echo "[chroot] Setting up PipeWire user services..."
USER_DINIT_DIR="/home/${USERNAME}/.config/dinit.d/boot.d"
mkdir -p "$USER_DINIT_DIR"

for svc in pipewire wireplumber; do
    # pipewire-dinit installs user service files to /etc/dinit.d/user/
    if [[ -f /etc/dinit.d/user/${svc} ]]; then
        ln -sf /etc/dinit.d/user/${svc} "${USER_DINIT_DIR}/${svc}"
        echo "  enabled user service: ${svc}"
    else
        echo "  [warn] /etc/dinit.d/user/${svc} not found — enable manually: dinitctl --user enable ${svc}"
    fi
done

chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}/.config/dinit.d"

# wireplumber: disable logind monitor (Artix has no logind in user session)
echo "[chroot] Configuring WirePlumber for logind-free setup..."
WP_CONF_DIR="/home/${USERNAME}/.config/wireplumber/wireplumber.conf.d"
mkdir -p "$WP_CONF_DIR"
cat > "${WP_CONF_DIR}/80-disable-logind.conf" <<'WPCFG'
wireplumber.profiles = {
  main = {
    monitor.bluez.seat-monitoring = disabled
  }
}
WPCFG
chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}/.config/wireplumber"

# ── yay (AUR helper) ─────────────────────────────────────────────────────────
echo "[chroot] Installing yay (AUR helper)..."
git clone https://aur.archlinux.org/yay-bin.git /tmp/yay-bin
chown -R "${USERNAME}:${USERNAME}" /tmp/yay-bin
su - "${USERNAME}" -c "cd /tmp/yay-bin && makepkg -si --noconfirm"
rm -rf /tmp/yay-bin

# ── AUR packages ─────────────────────────────────────────────────────────────
echo "[chroot] Installing Vesktop (AUR)..."
su - "${USERNAME}" -c "yay -S --noconfirm vesktop-bin" \
    || echo "[warn] vesktop-bin failed — run post-boot: yay -S vesktop-bin"

if [[ "${COMPOSITOR}" == "mangowm" ]]; then
    echo "[chroot] Installing mangowm (AUR)..."
    su - "${USERNAME}" -c "yay -S --noconfirm mangowm" \
        || echo "[warn] mangowm AUR install failed — run post-boot: yay -S mangowm"
fi

echo "[chroot] Installing Noctalia Shell (AUR)..."
su - "${USERNAME}" -c "yay -S --noconfirm noctalia-shell" \
    || su - "${USERNAME}" -c "yay -S --noconfirm noctalia-shell-git" \
    || echo "[warn] noctalia-shell not in AUR yet — install post-boot: yay -S noctalia-shell"

# ── XDG dirs ─────────────────────────────────────────────────────────────────
su - "${USERNAME}" -c "xdg-user-dirs-update" 2>/dev/null || true

echo "[chroot] Done!"
CHROOT_SCRIPT

    chmod +x "$MOUNT_ROOT/setup-chroot.sh"
    info_box "Entering chroot — this will take a while.\nDo not close this terminal."

    artix-chroot "$MOUNT_ROOT" \
        env \
            TIMEZONE="$TIMEZONE" \
            HOSTNAME="$HOSTNAME" \
            USERNAME="$USERNAME" \
            ROOT_PASSWORD="$ROOT_PASSWORD" \
            USER_PASSWORD="$USER_PASSWORD" \
            COMPOSITOR="$COMPOSITOR" \
        /bin/bash /setup-chroot.sh

    rm -f "$MOUNT_ROOT/setup-chroot.sh"
}

# ─── Phase 5: Cleanup ─────────────────────────────────────────────────────────
phase_cleanup() {
    info_box "Unmounting filesystems..."
    umount -R "$MOUNT_ROOT" 2>/dev/null || true
    swapoff -a 2>/dev/null || true
}

# ─── Main ─────────────────────────────────────────────────────────────────────
main() {
    collect_config
    clear
    echo "Starting Artix installation — this will take 20–60 minutes depending on your connection."
    echo

    phase_wifi
    phase_disk
    phase_basestrap
    phase_dotfiles
    phase_chroot
    phase_cleanup

    d --title "Done!" --yesno \
"Installation complete!

  Compositor:  $COMPOSITOR + Noctalia Shell
  Init:        dinit
  Audio:       PipeWire (user service via turnstile)
  Greeter:     sddm

PipeWire starts automatically on login via turnstile.
Run 'wpctl status' to verify audio is working.

If noctalia-shell wasn't in the AUR during install:
  yay -S noctalia-shell

Reboot now?" 20 60
    dialog_ok && reboot
}

main "$@"
