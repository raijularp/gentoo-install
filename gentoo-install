#!/usr/bin/env bash
# Gentoo Installation Script — vibecoded by Claude Code
# Run as root from the Gentoo minimal ISO

set -euo pipefail

MOUNT_ROOT="/mnt/gentoo"
STAGE3_MIRROR="https://distfiles.gentoo.org/releases/amd64/autobuilds"
BACKTITLE="Gentoo Installer  |  vibecoded by Claude Code  |  proof-of-concept"
TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

# ─── Sanity checks ────────────────────────────────────────────────────────────
[[ $EUID -ne 0 ]]        && { echo "Run as root."; exit 1; }
command -v dialog    &>/dev/null || { echo "dialog is required. Run: emerge dialog"; exit 1; }
command -v curl      &>/dev/null || { echo "curl is required.";   exit 1; }
command -v parted    &>/dev/null || { echo "parted is required."; exit 1; }
command -v mkfs.ext4 &>/dev/null || { echo "e2fsprogs is required."; exit 1; }

# ─── TUI helpers ──────────────────────────────────────────────────────────────
# All dialog calls write their result to $TMP via stderr redirect
d()      { dialog --backtitle "$BACKTITLE" "$@" 2>"$TMP"; }
result() { cat "$TMP"; }
die()    { dialog --backtitle "$BACKTITLE" --title "Fatal Error" --msgbox "$*" 8 60; exit 1; }
info_box() { dialog --backtitle "$BACKTITLE" --title "Installing..." --infobox "$*" 5 60; }

# ─── Configuration ────────────────────────────────────────────────────────────
collect_config() {
    d --title "Welcome" --msgbox \
"Gentoo Installation Script

This installer is fully vibecoded — written entirely by Claude Code
as a proof-of-concept. Use at your own risk.

It has not been formally tested. If it works for you — great.
If it doesn't — that is also useful information.

Press OK to begin." 13 64

    # ── Disk ──
    local disk_args=()
    while IFS= read -r line; do
        local name size model
        name=$(awk '{print $1}' <<< "$line")
        size=$(awk '{print $2}' <<< "$line")
        model=$(awk '{$1=$2=""; print $0}' <<< "$line" | xargs)
        disk_args+=("/dev/$name" "$size  $model")
    done < <(lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -v loop)

    d --title "Target Disk" \
      --menu "Select the disk to install Gentoo on.\nWARNING: it will be completely wiped." \
      18 70 8 "${disk_args[@]}"
    DISK=$(result)
    [[ -b "$DISK" ]] || die "No disk selected."

    # ── Firmware — auto-detected ──
    if [[ -d /sys/firmware/efi ]]; then
        SYS_FIRMWARE="uefi"
    else
        SYS_FIRMWARE="bios"
    fi
    d --title "Firmware" --msgbox \
"Auto-detected: ${SYS_FIRMWARE^^}

Firmware type has been detected from the live environment.
No action needed." 9 50

    # ── libc ──
    d --title "C Library" --menu "Choose your C library:" 11 66 2 \
        "glibc" "Default — broadest software compatibility" \
        "musl"  "Lightweight — if you're choosing this you likely know the downsides"
    LIBC=$(result)

    # ── Filesystem ──
    d --title "Root Filesystem" --menu "Choose the root filesystem:" 14 66 4 \
        "ext4"  "Solid, well-tested default" \
        "btrfs" "Copy-on-write, snapshots, checksums" \
        "xfs"   "High performance, good for large files" \
        "zfs"   "Advanced CoW, snapshots, built-in RAID (advanced)"
    FS_TYPE=$(result)

    if [[ "$FS_TYPE" == "zfs" ]]; then
        d --title "ZFS Notice" --yesno \
"ZFS root requires a separate /boot partition and ZFS kernel
modules built into the initramfs.

genkernel will be used regardless of your kernel method choice.

Continue with ZFS?" 10 60 || exit 0
    fi

    # ── Init system ──
    d --title "Init System" --menu "Choose your init system:" 16 72 5 \
        "openrc"  "Default Gentoo — lightweight, script-based" \
        "systemd" "Full systemd — journald, networkd, socket activation" \
        "runit"   "Supervision-based — very fast boot, minimal" \
        "s6"      "skarnet supervision suite — low overhead" \
        "dinit"   "Dependency-ordered, modern (experimental — not recommended)"
    INIT_SYSTEM=$(result)

    if [[ "$INIT_SYSTEM" == "systemd" && "$LIBC" == "musl" ]]; then
        die "systemd is not compatible with musl.\nPlease go back and choose a different init system or libc."
    fi

    if [[ "$INIT_SYSTEM" == "dinit" ]]; then
        d --title "dinit Warning" --yesno \
"dinit is experimental and may have limited service coverage
in the Gentoo ecosystem. Some packages may not have dinit
service files yet.

Are you sure you want to use dinit?" 10 58 || exit 0
    fi

    # ── Desktop / WM / Compositor ──
    d --title "Desktop Environment / WM" \
      --menu "Choose a desktop, window manager, or compositor:" 28 76 16 \
        "none"     "Bare system — no GUI" \
        "kde"      "KDE Plasma (Xorg)" \
        "gnome"    "GNOME (Xorg)" \
        "xfce"     "XFCE (Xorg)" \
        "i3"       "Tiling WM — keyboard-driven (Xorg)" \
        "openbox"  "Floating WM — highly configurable (Xorg)" \
        "bspwm"    "Binary space partitioning tiling WM (Xorg)" \
        "dwm"      "Suckless tiling WM — requires manual patching (Xorg)" \
        "sway"     "i3-compatible Wayland compositor — stable" \
        "hyprland" "Dynamic tiling Wayland — highly customizable" \
        "niri"     "Scrollable tiling Wayland compositor" \
        "river"    "Dynamic tiling Wayland — scriptable" \
        "wayfire"  "3D effects, plugin-based Wayland compositor" \
        "labwc"    "Openbox-like floating Wayland compositor" \
        "mangowm"  "Minimalist dwl-based Wayland compositor (GURU overlay)" \
        "weston"   "Reference Wayland compositor — very minimal"
    DESKTOP=$(result)

    if [[ "$DESKTOP" == "dwm" ]]; then
        d --title "DWM Warning" --yesno \
"dwm is designed to be patched and recompiled by hand.
The ebuild installs a stock unpatched build — you will
almost certainly want to customize it post-install.

Are you sure you want dwm?" 10 56 || exit 0
    fi

    # ── Kernel ──
    d --title "Kernel Build" --menu "Choose kernel build method:" 10 64 2 \
        "genkernel" "Automated — recommended for most users" \
        "manual"    "Manual — configure and compile yourself post-install"
    KERNEL_METHOD=$(result)

    # ── Timezone ──
    d --title "Timezone" --inputbox \
"Enter your timezone:\n(e.g. America/New_York, Europe/Berlin, Asia/Tokyo)" \
9 56 "UTC"
    TIMEZONE=$(result)
    [[ -n "$TIMEZONE" ]] || TIMEZONE="UTC"

    # ── Locale ──
    d --title "Locale" --inputbox "Enter your locale:" 8 50 "en_US.UTF-8"
    LOCALE=$(result)
    [[ -n "$LOCALE" ]] || LOCALE="en_US.UTF-8"

    # ── Hostname ──
    d --title "Hostname" --inputbox "Enter hostname for this machine:" 8 50 "gentoo"
    HOSTNAME=$(result)
    [[ -n "$HOSTNAME" ]] || HOSTNAME="gentoo"

    # ── Root password ──
    local pw1 pw2
    d --title "Root Password" --passwordbox "Enter root password:" 8 50
    pw1=$(result)
    d --title "Root Password" --passwordbox "Confirm root password:" 8 50
    pw2=$(result)
    [[ "$pw1" == "$pw2" ]] || die "Passwords do not match."
    [[ -n "$pw1" ]]         || die "Password cannot be empty."
    ROOT_PASSWORD="$pw1"

    # ── Summary + confirm ──
    d --title "Confirm Installation" --yesno \
"Installation Summary
────────────────────────────────────
  Disk:        $DISK
  Firmware:    $SYS_FIRMWARE
  libc:        $LIBC
  Filesystem:  $FS_TYPE
  Init system: $INIT_SYSTEM
  Desktop:     $DESKTOP
  Kernel:      $KERNEL_METHOD
  Timezone:    $TIMEZONE
  Hostname:    $HOSTNAME
────────────────────────────────────
  ALL DATA ON $DISK WILL BE DESTROYED.

Proceed with installation?" 22 52
}

# ─── Phase 1: Disk ────────────────────────────────────────────────────────────
phase_disk() {
    info_box "Unmounting any existing mounts on $DISK..."
    swapoff -a 2>/dev/null || true
    umount -R "$MOUNT_ROOT" 2>/dev/null || true
    for part in $(lsblk -lno NAME "$DISK" | tail -n +2); do
        umount -l "/dev/$part" 2>/dev/null || true
    done

    info_box "Partitioning $DISK..."
    [[ "$DISK" =~ nvme ]] && PART_PREFIX="${DISK}p" || PART_PREFIX="${DISK}"

    parted -s "$DISK" mklabel gpt

    if [[ "$FS_TYPE" == "zfs" ]]; then
        if [[ "$SYS_FIRMWARE" == "uefi" ]]; then
            parted -s "$DISK" mkpart ESP fat32 1MiB 513MiB
            parted -s "$DISK" set 1 esp on
            parted -s "$DISK" mkpart boot ext4 513MiB 1537MiB
            parted -s "$DISK" mkpart swap linux-swap 1537MiB 5633MiB
            parted -s "$DISK" mkpart root zfs 5633MiB 100%
            PART_EFI="${PART_PREFIX}1"; PART_BOOT="${PART_PREFIX}2"
            PART_SWAP="${PART_PREFIX}3"; PART_ROOT="${PART_PREFIX}4"
        else
            parted -s "$DISK" mkpart bios_grub 1MiB 3MiB
            parted -s "$DISK" set 1 bios_grub on
            parted -s "$DISK" mkpart boot ext4 3MiB 1027MiB
            parted -s "$DISK" mkpart swap linux-swap 1027MiB 5123MiB
            parted -s "$DISK" mkpart root zfs 5123MiB 100%
            PART_EFI=""; PART_BOOT="${PART_PREFIX}2"
            PART_SWAP="${PART_PREFIX}3"; PART_ROOT="${PART_PREFIX}4"
        fi
    elif [[ "$SYS_FIRMWARE" == "uefi" ]]; then
        parted -s "$DISK" mkpart ESP fat32 1MiB 513MiB
        parted -s "$DISK" set 1 esp on
        parted -s "$DISK" mkpart swap linux-swap 513MiB 4609MiB
        parted -s "$DISK" mkpart root "$FS_TYPE" 4609MiB 100%
        PART_EFI="${PART_PREFIX}1"; PART_SWAP="${PART_PREFIX}2"
        PART_ROOT="${PART_PREFIX}3"; PART_BOOT=""
    else
        parted -s "$DISK" mkpart bios_grub 1MiB 3MiB
        parted -s "$DISK" set 1 bios_grub on
        parted -s "$DISK" mkpart swap linux-swap 3MiB 4099MiB
        parted -s "$DISK" mkpart root "$FS_TYPE" 4099MiB 100%
        PART_SWAP="${PART_PREFIX}2"; PART_ROOT="${PART_PREFIX}3"
        PART_EFI=""; PART_BOOT=""
    fi

    info_box "Formatting partitions..."
    [[ -n "$PART_EFI"  ]] && mkfs.vfat -F32 "$PART_EFI"
    [[ -n "$PART_BOOT" ]] && mkfs.ext4 -F -L boot "$PART_BOOT"
    mkswap "$PART_SWAP" && swapon "$PART_SWAP"

    case "$FS_TYPE" in
        ext4)  mkfs.ext4  -F -L root "$PART_ROOT" ;;
        btrfs) mkfs.btrfs -f -L root "$PART_ROOT" ;;
        xfs)   mkfs.xfs   -f -L root "$PART_ROOT" ;;
        zfs)
            zpool destroy rpool 2>/dev/null || true
            zpool create -f \
                -o ashift=12 \
                -O acltype=posixacl -O compression=lz4 -O dnodesize=auto \
                -O normalization=formD -O relatime=on -O xattr=sa \
                -O mountpoint=none rpool "$PART_ROOT"
            zfs create -o mountpoint=/ rpool/root
            zfs create -o mountpoint=/home rpool/home
            zfs create -o mountpoint=/var/log rpool/log
            zpool export rpool
            ;;
    esac

    info_box "Mounting filesystems..."
    mkdir -p "$MOUNT_ROOT"
    if [[ "$FS_TYPE" == "zfs" ]]; then
        zpool import -d "/dev/disk/by-id" -R "$MOUNT_ROOT" rpool
        zfs mount rpool/root
        zfs mount rpool/home
        zfs mount rpool/log
    else
        mount "$PART_ROOT" "$MOUNT_ROOT"
    fi
    [[ -n "$PART_BOOT" ]] && { mkdir -p "$MOUNT_ROOT/boot"; mount "$PART_BOOT" "$MOUNT_ROOT/boot"; }
    [[ -n "$PART_EFI"  ]] && { mkdir -p "$MOUNT_ROOT/boot/efi"; mount "$PART_EFI" "$MOUNT_ROOT/boot/efi"; }
}

# ─── Phase 2: Stage3 ──────────────────────────────────────────────────────────
phase_stage3() {
    info_box "Fetching latest stage3 URL..."

    local stage3_variant stage3_dir
    if [[ "$LIBC" == "musl" ]]; then
        case "$INIT_SYSTEM" in
            openrc) stage3_variant="amd64-musl";        stage3_dir="current-stage3-amd64-musl" ;;
            *)      stage3_variant="amd64-musl-openrc"; stage3_dir="current-stage3-amd64-musl-openrc" ;;
        esac
    else
        case "$INIT_SYSTEM" in
            openrc)  stage3_variant="amd64-openrc";  stage3_dir="current-stage3-amd64-openrc" ;;
            systemd) stage3_variant="amd64-systemd"; stage3_dir="current-stage3-amd64-systemd" ;;
            runit)   stage3_variant="amd64-runit";   stage3_dir="current-stage3-amd64-runit" ;;
            s6)      stage3_variant="amd64-s6";      stage3_dir="current-stage3-amd64-s6" ;;
            dinit)   stage3_variant="amd64-dinit";   stage3_dir="current-stage3-amd64-dinit" ;;
        esac
    fi

    local latest_url="${STAGE3_MIRROR}/${stage3_dir}/latest-stage3-${stage3_variant}.txt"
    local stage3_file
    stage3_file=$(curl -s "$latest_url" \
        | grep -v '^#' | grep -v '^-' | grep '\.tar\.' | awk '{print $1}' | head -1)
    [[ -n "$stage3_file" ]] || die "Failed to fetch stage3 URL for ${INIT_SYSTEM}."

    local stage3_url="${STAGE3_MIRROR}/${stage3_dir}/${stage3_file}"
    info_box "Downloading $stage3_file\n(this may take several minutes...)"
    cd "$MOUNT_ROOT"
    curl -L -O "${stage3_url}"
    curl -L -O "${stage3_url}.sha256"
    curl -L -O "${stage3_url}.asc"

    info_box "Verifying checksum..."
    sha256sum -c "${stage3_file}.sha256" || die "Stage3 checksum verification failed."

    info_box "Extracting stage3..."
    tar xpf "$stage3_file" --xattrs-include='*.*' --numeric-owner
    rm -f "$stage3_file" "${stage3_file}.sha256" "${stage3_file}.asc"
    cd /
}

# ─── Phase 3: Portage ─────────────────────────────────────────────────────────
phase_portage() {
    info_box "Configuring make.conf..."

    local cpu_count march use_flags
    cpu_count=$(nproc)
    march=$(gcc -march=native -Q --help=target 2>/dev/null | grep '^\s*-march=' | awk '{print $2}' || echo "native")

    use_flags="-bluetooth"
    if [[ "$DESKTOP" =~ ^(sway|hyprland|niri|river|wayfire|labwc|mangowm|weston)$ ]]; then
        use_flags="wayland $use_flags"
    elif [[ "$DESKTOP" != "none" ]]; then
        use_flags="X alsa pulseaudio $use_flags"
    fi
    case "$DESKTOP" in
        kde)     use_flags="$use_flags kde plasma" ;;
        gnome)   use_flags="$use_flags gnome" ;;
        xfce)    use_flags="$use_flags xfce gtk" ;;
        wayfire) use_flags="$use_flags gtk opengl" ;;
        *)       [[ "$DESKTOP" != "none" ]] && use_flags="$use_flags gtk" ;;
    esac

    cat > "$MOUNT_ROOT/etc/portage/make.conf" <<EOF
# make.conf — generated by gentoo-install (vibecoded by Claude Code)
COMMON_FLAGS="-march=${march} -O2 -pipe"
CFLAGS="\${COMMON_FLAGS}"
CXXFLAGS="\${COMMON_FLAGS}"
FCFLAGS="\${COMMON_FLAGS}"
FFLAGS="\${COMMON_FLAGS}"

MAKEOPTS="-j${cpu_count}"
EMERGE_DEFAULT_OPTS="--jobs=${cpu_count} --load-average=${cpu_count}"

USE="${use_flags}"

GRUB_PLATFORMS="${SYS_FIRMWARE}"
VIDEO_CARDS="intel amdgpu radeon nouveau"
INPUT_DEVICES="libinput"

ACCEPT_LICENSE="*"
ACCEPT_KEYWORDS="amd64"

GENTOO_MIRRORS="https://distfiles.gentoo.org"
EOF

    cp --dereference /etc/resolv.conf "$MOUNT_ROOT/etc/"
}

# ─── Phase 4: Chroot ──────────────────────────────────────────────────────────
phase_chroot() {
    info_box "Mounting virtual filesystems..."
    mount --types proc  /proc "$MOUNT_ROOT/proc"
    mount --rbind        /sys  "$MOUNT_ROOT/sys"
    mount --make-rslave        "$MOUNT_ROOT/sys"
    mount --rbind        /dev  "$MOUNT_ROOT/dev"
    mount --make-rslave        "$MOUNT_ROOT/dev"
    mount --bind         /run  "$MOUNT_ROOT/run" 2>/dev/null || true

    local fstab_efi="" fstab_boot="" root_uuid=""
    if [[ "$SYS_FIRMWARE" == "uefi" && -n "$PART_EFI" ]]; then
        local efi_uuid; efi_uuid=$(blkid -s UUID -o value "$PART_EFI")
        fstab_efi="UUID=${efi_uuid}  /boot/efi  vfat  defaults  0 2"
    fi
    if [[ -n "$PART_BOOT" ]]; then
        local boot_uuid; boot_uuid=$(blkid -s UUID -o value "$PART_BOOT")
        fstab_boot="UUID=${boot_uuid}  /boot  ext4  defaults,noatime  0 2"
    fi
    [[ "$FS_TYPE" != "zfs" ]] && root_uuid=$(blkid -s UUID -o value "$PART_ROOT")
    local swap_uuid; swap_uuid=$(blkid -s UUID -o value "$PART_SWAP")

    local grub_target
    [[ "$SYS_FIRMWARE" == "uefi" ]] \
        && grub_target="--target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Gentoo" \
        || grub_target="--target=i386-pc $DISK"

    local WAYLAND_BASE="sys-auth/seatd x11-terms/alacritty gui-apps/waybar gui-apps/wofi"
    local desktop_pkgs=""
    case "$DESKTOP" in
        kde)      desktop_pkgs="kde-plasma/plasma-meta kde-apps/kde-apps-meta x11-base/xorg-server" ;;
        gnome)    desktop_pkgs="gnome-base/gnome x11-base/xorg-server" ;;
        xfce)     desktop_pkgs="xfce-base/xfce4-meta x11-base/xorg-server" ;;
        i3)       desktop_pkgs="x11-wm/i3 x11-misc/i3status x11-misc/dmenu x11-terms/alacritty x11-base/xorg-server" ;;
        openbox)  desktop_pkgs="x11-wm/openbox x11-misc/tint2 x11-misc/dmenu x11-terms/alacritty x11-base/xorg-server" ;;
        bspwm)    desktop_pkgs="x11-wm/bspwm x11-misc/sxhkd x11-misc/dmenu x11-terms/alacritty x11-base/xorg-server" ;;
        dwm)      desktop_pkgs="x11-wm/dwm x11-terms/st x11-base/xorg-server" ;;
        sway)     desktop_pkgs="gui-wm/sway $WAYLAND_BASE" ;;
        hyprland) desktop_pkgs="gui-wm/hyprland gui-apps/hyprpaper $WAYLAND_BASE" ;;
        niri)     desktop_pkgs="gui-wm/niri $WAYLAND_BASE" ;;
        river)    desktop_pkgs="gui-wm/river $WAYLAND_BASE" ;;
        wayfire)  desktop_pkgs="gui-wm/wayfire gui-wm/wcm $WAYLAND_BASE" ;;
        labwc)    desktop_pkgs="gui-wm/labwc $WAYLAND_BASE" ;;
        mangowm)  desktop_pkgs="gui-wm/mangowm gui-libs/scenefx $WAYLAND_BASE" ;;
        weston)   desktop_pkgs="gui-libs/weston x11-terms/alacritty sys-auth/seatd" ;;
    esac

    local dm_pkg="" dm_service=""
    case "$DESKTOP" in
        kde)   dm_pkg="x11-misc/sddm";  dm_service="sddm" ;;
        gnome) dm_pkg="gnome-base/gdm"; dm_service="gdm" ;;
        xfce|i3|openbox|bspwm|dwm)
               dm_pkg="x11-misc/lightdm x11-misc/lightdm-gtk-greeter"; dm_service="lightdm" ;;
        sway|hyprland|niri|river|wayfire|labwc|mangowm|weston)
               dm_pkg="gui-apps/greetd gui-apps/greetd-tuigreet"; dm_service="greetd" ;;
    esac

    info_box "Writing chroot setup script..."
    cat > "$MOUNT_ROOT/setup-chroot.sh" <<'CHROOT_SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

echo "[chroot] Syncing Portage tree..."
emerge-webrsync -q

echo "[chroot] Selecting profile..."
if [[ "${LIBC}" == "musl" ]]; then
    eselect profile set default/linux/amd64/23.0/musl
else
    case "${INIT_SYSTEM}" in
        systemd) eselect profile set default/linux/amd64/23.0/systemd ;;
        *)       eselect profile set default/linux/amd64/23.0 ;;
    esac
fi

echo "[chroot] Setting timezone..."
echo "${TIMEZONE}" > /etc/timezone
emerge --config sys-libs/timezone-data

echo "[chroot] Setting locale..."
echo "${LOCALE} UTF-8" >> /etc/locale.gen
locale-gen
eselect locale set "$(locale -a | grep -i "${LOCALE%%.*}" | head -1)"
env-update
source /etc/profile 2>/dev/null || true

echo "[chroot] Installing kernel sources..."
emerge -q sys-kernel/gentoo-sources sys-kernel/linux-firmware
eselect kernel set 1

if [[ "${FS_TYPE}" == "zfs" ]]; then
    echo "[chroot] Installing ZFS..."
    emerge -q sys-fs/zfs sys-fs/zfs-kmod
    zgenhostid
    case "${INIT_SYSTEM}" in
        openrc)
            rc-update add zfs-import boot
            rc-update add zfs-mount boot
            rc-update add zfs-share default
            ;;
        systemd)
            systemctl enable zfs-import-cache zfs-import.target zfs-mount zfs-share zfs.target
            ;;
    esac
fi

if [[ "${KERNEL_METHOD}" == "genkernel" || "${FS_TYPE}" == "zfs" ]]; then
    emerge -q sys-kernel/genkernel
    [[ "${FS_TYPE}" == "zfs" ]] && genkernel --zfs all || genkernel all
elif [[ "${KERNEL_METHOD}" == "manual" ]]; then
    echo "[chroot] Kernel sources at /usr/src/linux — compile manually post-install."
fi

echo "[chroot] Writing fstab..."
if [[ "${FS_TYPE}" == "zfs" ]]; then
    cat > /etc/fstab <<FSTAB
# ZFS datasets are mounted by the initramfs — no root entry needed
UUID=${swap_uuid}  none  swap  sw  0 0
${fstab_boot}
${fstab_efi}
FSTAB
else
    cat > /etc/fstab <<FSTAB
UUID=${root_uuid}  /     ${FS_TYPE}  defaults,noatime  0 1
UUID=${swap_uuid}  none  swap        sw                0 0
${fstab_boot}
${fstab_efi}
FSTAB
fi

echo "[chroot] Setting hostname..."
echo "${HOSTNAME}" > /etc/hostname

echo "[chroot] Configuring network..."
emerge -q net-misc/dhcpcd

case "${INIT_SYSTEM}" in
    openrc)
        echo 'config_eth0="dhcp"' >> /etc/conf.d/net
        ln -sf /etc/init.d/net.lo /etc/init.d/net.eth0
        rc-update add net.eth0 default
        rc-update add dhcpcd default
        ;;
    systemd)
        systemctl enable systemd-networkd systemd-resolved
        mkdir -p /etc/systemd/network
        cat > /etc/systemd/network/20-dhcp.network <<NET
[Match]
Name=en*
[Network]
DHCP=yes
NET
        ;;
    runit)
        # runit stage3 only ships agetty services — write run scripts manually
        # Service repo: /etc/sv   Scan dir: /etc/service
        mkdir -p /etc/sv/dhcpcd /etc/service
        cat > /etc/sv/dhcpcd/run <<'RUN'
#!/bin/sh
exec dhcpcd -B -q
RUN
        chmod +x /etc/sv/dhcpcd/run
        ln -sf /etc/sv/dhcpcd /etc/service/dhcpcd
        ;;
    s6)
        mkdir -p /etc/s6/adminsv/dhcpcd /etc/s6/adminsv/default/contents.d
        cat > /etc/s6/adminsv/dhcpcd/run <<'RUN'
#!/bin/execlineb -P
dhcpcd -B -q
RUN
        chmod +x /etc/s6/adminsv/dhcpcd/run
        ln -sf /etc/s6/adminsv/dhcpcd /etc/s6/adminsv/default/contents.d/dhcpcd
        ;;
    dinit)
        emerge -q net-misc/dhcpcd
        dinitctl enable dhcpcd
        ;;
esac

echo "[chroot] Setting root password..."
echo "root:${ROOT_PASSWORD}" | chpasswd

echo "[chroot] Installing base system tools..."
emerge -q app-admin/sysklogd sys-process/cronie sys-apps/mlocate net-misc/ntp

case "${INIT_SYSTEM}" in
    openrc)
        rc-update add sysklogd default
        rc-update add cronie default
        rc-update add ntpd default
        ;;
    systemd)
        systemctl enable cronie ntpd
        ;;
    runit)
        # Write run scripts for each service — stage3 doesn't ship them
        for svc in sysklogd cronie ntpd; do
            mkdir -p /etc/sv/${svc}
        done
        cat > /etc/sv/sysklogd/run <<'RUN'
#!/bin/sh
exec syslogd -n
RUN
        cat > /etc/sv/cronie/run <<'RUN'
#!/bin/sh
exec crond -n
RUN
        cat > /etc/sv/ntpd/run <<'RUN'
#!/bin/sh
exec ntpd -n -g
RUN
        for svc in sysklogd cronie ntpd; do
            chmod +x /etc/sv/${svc}/run
            ln -sf /etc/sv/${svc} /etc/service/${svc}
        done
        ;;
    s6)
        for svc in sysklogd cronie ntpd; do
            ln -sf /etc/s6/adminsv/${svc} /etc/s6/adminsv/default/contents.d/${svc}
        done
        ;;
    dinit)
        for svc in sysklogd cronie ntpd; do dinitctl enable ${svc}; done
        ;;
esac

echo "[chroot] Installing GRUB..."
mkdir -p /etc/portage/package.use
if [[ "${SYS_FIRMWARE}" == "uefi" ]]; then
    echo "sys-boot/grub:2 grub_platforms_efi-64" >> /etc/portage/package.use/grub
else
    echo "sys-boot/grub:2 grub_platforms_pc" >> /etc/portage/package.use/grub
fi
emerge -q sys-boot/grub
grub-install ${grub_target}
grub-mkconfig -o /boot/grub/grub.cfg

if [[ -n "${desktop_pkgs}" ]]; then
    echo "[chroot] Installing desktop environment (this will take a while)..."

    if [[ "${DESKTOP}" == "mangowm" ]]; then
        emerge -q app-eselect/eselect-repository dev-vcs/git
        eselect repository enable guru
        emerge --sync guru
        mkdir -p /etc/portage/package.accept_keywords
        echo "gui-wm/mangowm ~amd64"   >> /etc/portage/package.accept_keywords/mangowm
        echo "gui-libs/scenefx ~amd64" >> /etc/portage/package.accept_keywords/mangowm
    fi

    emerge -q ${desktop_pkgs} ${dm_pkg}

    if [[ -n "${dm_service}" ]]; then
        case "${INIT_SYSTEM}" in
            openrc)  rc-update add ${dm_service} default ;;
            systemd) systemctl enable ${dm_service} ;;
            runit)
                mkdir -p /etc/sv/${dm_service}
                cat > /etc/sv/${dm_service}/run <<RUN
#!/bin/sh
exec ${dm_service}
RUN
                chmod +x /etc/sv/${dm_service}/run
                ln -sf /etc/sv/${dm_service} /etc/service/${dm_service}
                ;;
            s6)    ln -sf /etc/s6/adminsv/${dm_service} /etc/s6/adminsv/default/contents.d/${dm_service} ;;
            dinit) dinitctl enable ${dm_service} ;;
        esac
    fi
fi

echo "[chroot] Done!"
CHROOT_SCRIPT

    chmod +x "$MOUNT_ROOT/setup-chroot.sh"

    info_box "Entering chroot — this will take a while...\nDo not close this terminal."
    env -i \
        HOME=/root PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
        TERM=linux DEBUGINFOD_URLS="" DEBUGINFOD_IMA_CERT_PATH="" \
        INIT_SYSTEM="$INIT_SYSTEM" \
        TIMEZONE="$TIMEZONE" \
        LOCALE="$LOCALE" \
        KERNEL_METHOD="$KERNEL_METHOD" \
        HOSTNAME="$HOSTNAME" \
        ROOT_PASSWORD="$ROOT_PASSWORD" \
        SYS_FIRMWARE="$SYS_FIRMWARE" \
        FS_TYPE="$FS_TYPE" \
        DISK="$DISK" \
        DESKTOP="$DESKTOP" \
        LIBC="$LIBC" \
        root_uuid="$root_uuid" \
        swap_uuid="$swap_uuid" \
        fstab_efi="$fstab_efi" \
        fstab_boot="$fstab_boot" \
        grub_target="$grub_target" \
        desktop_pkgs="$desktop_pkgs" \
        dm_pkg="$dm_pkg" \
        dm_service="$dm_service" \
        chroot "$MOUNT_ROOT" /bin/bash /setup-chroot.sh

    rm -f "$MOUNT_ROOT/setup-chroot.sh"
}

# ─── Phase 5: Cleanup ─────────────────────────────────────────────────────────
phase_cleanup() {
    info_box "Unmounting filesystems..."
    umount -l "$MOUNT_ROOT/dev"  2>/dev/null || true
    umount -l "$MOUNT_ROOT/sys"  2>/dev/null || true
    umount -l "$MOUNT_ROOT/proc" 2>/dev/null || true
    umount -R "$MOUNT_ROOT"      2>/dev/null || true
    if [[ "$FS_TYPE" == "zfs" ]]; then
        zfs unmount -a  2>/dev/null || true
        zpool export rpool 2>/dev/null || true
    fi
    swapoff "$PART_SWAP" 2>/dev/null || true
}

# ─── Main ─────────────────────────────────────────────────────────────────────
main() {
    collect_config

    clear
    echo "Starting installation — this will take 30–90+ minutes."
    echo "Output will scroll below. Do not close this terminal."
    echo

    phase_disk
    phase_stage3
    phase_portage
    phase_chroot
    phase_cleanup

    local msg="Installation complete!\n\nReboot into your new Gentoo system."
    if [[ "$KERNEL_METHOD" == "manual" ]]; then
        msg+="\n\nManual kernel: chroot back in, compile at /usr/src/linux,\nthen run: grub-mkconfig -o /boot/grub/grub.cfg"
    fi

    d --title "Done!" --yesno "${msg}\n\nReboot now?" 16 58 && reboot
}

main "$@"
