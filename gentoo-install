#!/usr/bin/env bash
# Gentoo Installation Script — vibecoded by Claude Code
# Run as root from the Gentoo minimal ISO

set -euo pipefail

MOUNT_ROOT="/mnt/gentoo"
STAGE3_MIRROR="https://distfiles.gentoo.org/releases/amd64/autobuilds"
BACKTITLE="Gentoo Installer  |  vibecoded by Claude Code  |  proof-of-concept"
TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

# ─── Sanity checks ────────────────────────────────────────────────────────────
if [[ $EUID -ne 0 ]]; then echo "Run as root."; exit 1; fi
command -v dialog    &>/dev/null || { echo "dialog is required. Run: emerge dialog"; exit 1; }
command -v curl      &>/dev/null || { echo "curl is required.";   exit 1; }
command -v parted    &>/dev/null || { echo "parted is required."; exit 1; }
command -v mkfs.ext4 &>/dev/null || { echo "e2fsprogs is required."; exit 1; }

# ─── TUI helpers ──────────────────────────────────────────────────────────────
# All dialog calls write their result to $TMP via stderr redirect
_DIALOG_EXIT=0
d()      { _DIALOG_EXIT=0; dialog --backtitle "$BACKTITLE" "$@" 2>"$TMP" || _DIALOG_EXIT=$?; }
result() { cat "$TMP"; }
dialog_ok() { [[ $_DIALOG_EXIT -eq 0 ]]; }
die()    { dialog --backtitle "$BACKTITLE" --title "Fatal Error" --msgbox "$*" 8 60; exit 1; }
info_box() { dialog --backtitle "$BACKTITLE" --title "Installing..." --infobox "$*" 5 60; }

# ─── Timezone picker ──────────────────────────────────────────────────────────
pick_timezone() {
    local zoneroot="/usr/share/zoneinfo"

    # Step 1 — region
    local region_args=()
    while IFS= read -r r; do
        region_args+=("$r" "")
    done < <(ls "$zoneroot" | grep -E '^[A-Z]' | grep -v '^posix$' | grep -v '^right$' | sort)

    d --title "Timezone — Region" --menu "Select your region:" 24 50 16 "${region_args[@]}"
    local region; region=$(result)
    if [[ -z "$region" ]]; then TIMEZONE="UTC"; return; fi

    if [[ -d "$zoneroot/$region" ]]; then
        # Step 2 — city (flattened, handles sub-dirs like America/Indiana/Indianapolis)
        local city_args=()
        while IFS= read -r c; do
            city_args+=("$c" "")
        done < <(find "$zoneroot/$region" -type f | sed "s|$zoneroot/$region/||" | sort)

        d --title "Timezone — $region" --menu "Select your city:" 24 56 16 "${city_args[@]}"
        local city; city=$(result)
        if [[ -z "$city" ]]; then TIMEZONE="UTC"; return; fi
        TIMEZONE="$region/$city"
    else
        TIMEZONE="$region"
    fi
}

# ─── Configuration ────────────────────────────────────────────────────────────
# ─── Raiju mode ───────────────────────────────────────────────────────────────
collect_raiju_config() {
    d --title "Raiju Mode" --msgbox \
"Raiju Mode selected.

This is a personal preset for raiju — not for general use.

Preset:
  Compositor:  niri  OR  mangowm  (your choice)
  Init:        your choice
  Shell:       Noctalia Shell (via GURU overlay)
  Audio:       PipeWire + WirePlumber (autostarted)
  Greeter:     ly (TUI display manager)
  libc:        glibc
  Filesystem:  xfs
  Kernel:      genkernel

You still choose: disk, compositor, init, timezone, hostname, password." 22 60

    # ── Disk ──
    local disk_args=()
    while IFS= read -r line; do
        local name size model
        name=$(awk '{print $1}' <<< "$line")
        size=$(awk '{print $2}' <<< "$line")
        model=$(awk '{$1=$2=""; print $0}' <<< "$line" | xargs)
        disk_args+=("/dev/$name" "$size  $model")
    done < <(lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -v loop)

    d --title "Target Disk" \
      --menu "Select the disk to install Gentoo on.\nWARNING: it will be completely wiped." \
      18 70 8 "${disk_args[@]}"
    DISK=$(result)
    [[ -b "$DISK" ]] || die "No disk selected."

    # ── Firmware ──
    [[ -d /sys/firmware/efi ]] && SYS_FIRMWARE="uefi" || SYS_FIRMWARE="bios"

    # ── Compositor ──
    d --title "Raiju — Compositor" --menu "Choose your compositor:" 10 60 2 \
        "niri"    "Niri — scrollable tiling (recommended)" \
        "mangowm" "Mangowm — minimalist dwl-based"
    RAIJU_COMPOSITOR=$(result)

    # ── Init system ──
    d --title "Raiju — Init System" --menu "Choose your init system:" 16 72 5 \
        "openrc"  "OpenRC — lightweight, script-based (recommended)" \
        "systemd" "systemd — full featured, journald, socket activation" \
        "runit"   "runit — supervision-based, very fast boot" \
        "s6"      "s6 — skarnet supervision suite, low overhead" \
        "dinit"   "becareful — experimental, not recommended"
    INIT_SYSTEM=$(result)

    # ── Timezone ──
    pick_timezone

    # ── Hostname ──
    d --title "Hostname" --inputbox "Enter hostname:" 8 50 "raiju"
    HOSTNAME=$(result); [[ -n "$HOSTNAME" ]] || HOSTNAME="raiju"

    # ── Root password ──
    local pw1 pw2
    d --title "Root Password" --passwordbox "Enter root password:" 8 50; pw1=$(result)
    d --title "Root Password" --passwordbox "Confirm root password:" 8 50; pw2=$(result)
    [[ "$pw1" == "$pw2" ]] || die "Passwords do not match."
    [[ -n "$pw1" ]]         || die "Password cannot be empty."
    ROOT_PASSWORD="$pw1"

    # ── Libreboot ──
    d --title "Raiju — Bootloader" --yesno \
"Are you installing on a Libreboot machine (e.g. T480)?

Yes  — generate grub.cfg only (GRUB already in firmware)
No   — install GRUB normally" 10 58
    if dialog_ok; then
        BOOTLOADER="libreboot"
    else
        BOOTLOADER="grub"
    fi

    # Set fixed preset values
    CUSTOM_USE=""
    LIBC="glibc"
    FS_TYPE="xfs"
    KERNEL_METHOD="genkernel"
    LOCALE="en_US.UTF-8"
    AUDIO="pipewire"
    GREETER="ly"
    DESKTOP="$RAIJU_COMPOSITOR"

    d --title "Raiju — Confirm" --yesno \
"Raiju Mode Summary
──────────────────────────────────
  Disk:        $DISK
  Firmware:    $SYS_FIRMWARE
  Compositor:  $RAIJU_COMPOSITOR + Noctalia Shell
  Audio:       PipeWire (autostarted)
  Init:        $INIT_SYSTEM
  Bootloader:  $BOOTLOADER
  Filesystem:  xfs
  Timezone:    $TIMEZONE
  Hostname:    $HOSTNAME
──────────────────────────────────
  ALL DATA ON $DISK WILL BE DESTROYED.

Proceed?" 24 50
    dialog_ok || exit 0

    RAIJU_MODE=1
    USERNAME="raiju"
    USER_PASSWORD="$ROOT_PASSWORD"
}

