input {
    keyboard { xkb { layout "us" } }
    touchpad { tap; natural-scroll; }
    mouse { natural-scroll false; }
}

output "eDP-1" { scale 1.0; }

layout {
    gaps 8
    center-focused-column "never"
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }
    default-column-width { proportion 0.5; }
    focus-ring { off; }
