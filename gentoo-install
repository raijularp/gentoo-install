Comment=Scrollable tiling Wayland compositor
Exec=niri-session
Type=Application
DesktopNames=niri
DESK
    elif [[ "$RAIJU_COMPOSITOR" == "mangowm" ]]; then
        cat > "$session_dir/mangowm.desktop" <<'DESK'
[Desktop Entry]
Name=mangowm
Comment=Minimalist Wayland compositor
Exec=mangowm
Type=Application
DesktopNames=mangowm
DESK
    fi

    # Fix ownership — dotfiles were written as root from the live env
    chown -R 1000:1000 "$home"
}

collect_config() {
    d --title "Welcome" --msgbox \
"Gentoo Installation Script

This installer is fully vibecoded — written entirely by Claude Code
as a proof-of-concept. Use at your own risk.

It has not been formally tested. If it works for you — great.
If it doesn't — that is also useful information.

Press OK to begin." 13 64

    # ── Mode selection ──
    d --title "Mode" --menu "Select installation mode:" 12 66 2 \
        "normal"  "Regular user mode — choose everything yourself" \
        "raiju"   "Raiju mode — personal preset (for raiju only, don't touch)"
    local MODE; MODE=$(result)

    if [[ "$MODE" == "raiju" ]]; then
        collect_raiju_config
        return
    fi

    # ── Disk ──
    local disk_args=()
    while IFS= read -r line; do
        local name size model
        name=$(awk '{print $1}' <<< "$line")
        size=$(awk '{print $2}' <<< "$line")
        model=$(awk '{$1=$2=""; print $0}' <<< "$line" | xargs)
        disk_args+=("/dev/$name" "$size  $model")
    done < <(lsblk -d -o NAME,SIZE,MODEL --noheadings | grep -v loop)

    d --title "Target Disk" \
      --menu "Select the disk to install Gentoo on.\nWARNING: it will be completely wiped." \
      18 70 8 "${disk_args[@]}"
    DISK=$(result)
    [[ -b "$DISK" ]] || die "No disk selected."

    # ── Firmware — auto-detected ──
    if [[ -d /sys/firmware/efi ]]; then
        SYS_FIRMWARE="uefi"
    else
        SYS_FIRMWARE="bios"
    fi
    d --title "Firmware" --msgbox \
"Auto-detected: ${SYS_FIRMWARE^^}

Firmware type has been detected from the live environment.
No action needed." 9 50

    # ── libc ──
    d --title "C Library" --menu "Choose your C library:" 11 66 2 \
        "glibc" "Default — broadest software compatibility" \
        "musl"  "Lightweight — if you're choosing this you likely know the downsides"
    LIBC=$(result)

    # ── Filesystem ──
    d --title "Root Filesystem" --menu "Choose the root filesystem:" 14 66 4 \
        "ext4"  "Solid, well-tested default" \
        "btrfs" "Copy-on-write, snapshots, checksums" \
        "xfs"   "High performance, good for large files" \
        "zfs"   "Advanced CoW, snapshots, built-in RAID (advanced)"
    FS_TYPE=$(result)

    if [[ "$FS_TYPE" == "zfs" ]]; then
        d --title "ZFS Notice" --yesno \
"ZFS root requires a separate /boot partition and ZFS kernel
modules built into the initramfs.

genkernel will be used regardless of your kernel method choice.

Continue with ZFS?" 10 60
        dialog_ok || exit 0
    fi

    # ── Init system ──
    d --title "Init System" --menu "Choose your init system:" 16 72 5 \
        "openrc"  "Default Gentoo — lightweight, script-based" \
        "systemd" "Full systemd — journald, networkd, socket activation" \
        "runit"   "Supervision-based — very fast boot, minimal" \
        "s6"      "skarnet supervision suite — low overhead" \
        "dinit"   "becareful — experimental, limited service coverage, not recommended"
    INIT_SYSTEM=$(result)

    if [[ "$INIT_SYSTEM" == "systemd" && "$LIBC" == "musl" ]]; then
        die "systemd is not compatible with musl.\nPlease go back and choose a different init system or libc."
    fi

    if [[ "$INIT_SYSTEM" == "dinit" ]]; then
        d --title "dinit Warning" --yesno \
"dinit is experimental and may have limited service coverage
in the Gentoo ecosystem. Some packages may not have dinit
service files yet.

Are you sure you want to use dinit?" 10 58
        dialog_ok || exit 0
    fi

    # ── Desktop / WM / Compositor ──
    d --title "Desktop Environment / WM" \
      --menu "Choose a desktop, window manager, or compositor:" 28 76 16 \
        "none"     "Bare system — no GUI" \
        "kde"      "KDE Plasma (X11)" \
        "gnome"    "GNOME (X11)" \
        "xfce"     "XFCE (X11)" \
        "i3"       "Tiling WM — keyboard-driven (X11)" \
        "openbox"  "Floating WM — highly configurable (X11)" \
        "bspwm"    "Binary space partitioning tiling WM (X11)" \
        "dwm"      "Suckless tiling WM — requires manual patching (X11)" \
        "sway"     "i3-compatible Wayland compositor — stable" \
        "hyprland" "Dynamic tiling Wayland — highly customizable" \
        "niri"     "Scrollable tiling Wayland compositor" \
        "river"    "Dynamic tiling Wayland — scriptable" \
        "wayfire"  "3D effects, plugin-based Wayland compositor" \
        "labwc"    "Openbox-like floating Wayland compositor" \
        "mangowm"  "Minimalist dwl-based Wayland compositor (GURU overlay)" \
        "weston"   "Reference Wayland compositor — very minimal"
    DESKTOP=$(result)

    if [[ "$DESKTOP" == "dwm" ]]; then
        d --title "DWM Warning" --yesno \
"dwm is designed to be patched and recompiled by hand.
The ebuild installs a stock unpatched build — you will
almost certainly want to customize it post-install.

Are you sure you want dwm?" 10 56
        dialog_ok || exit 0
    fi

    # ── Display server ──
    XSERVER=""
    if [[ "$DESKTOP" =~ ^(kde|gnome|xfce|i3|openbox|bspwm|dwm)$ ]]; then
        d --title "X11 Server" --menu "Choose an X11 display server:" 12 70 3 \
            "xorg"    "Xorg — standard, well-tested (recommended)" \
            "xlibre"  "XLibre — community Xorg fork, more active development" \
            "none"    "Skip — I will install it manually"
        XSERVER=$(result)
        [[ -z "$XSERVER" ]] && XSERVER="xorg"
    elif [[ "$DESKTOP" == "none" ]]; then
        d --title "Display Protocol" --menu "Install a display server/protocol?" 14 70 4 \
            "none"    "No display server — stay headless" \
            "xorg"    "Xorg — X11 display server" \
            "xlibre"  "XLibre — community Xorg fork" \
            "wayland" "Wayland libs only — no compositor"
        XSERVER=$(result)
        [[ -z "$XSERVER" ]] && XSERVER="none"
    fi

    # ── Audio ──
    AUDIO="none"
    if [[ "$DESKTOP" != "none" ]]; then
        d --title "Audio" --menu "Choose an audio server:" 12 66 3 \
            "pipewire"   "Modern — handles audio + video, replaces PulseAudio (recommended)" \
            "pulseaudio" "Classic — rock solid, broadest app compatibility" \
            "none"       "No audio server — configure manually later"
        AUDIO=$(result)
    fi

    # ── Greeter ──
    GREETER=""
    if [[ "$DESKTOP" =~ ^(xfce|i3|openbox|bspwm|dwm)$ ]]; then
        d --title "Greeter" --menu "Choose a LightDM greeter:" 10 66 2 \
            "gtk"   "GTK greeter — simple and clean (default)" \
            "slick" "Slick greeter — modern, user avatar support"
        GREETER=$(result)
    elif [[ "$DESKTOP" =~ ^(sway|hyprland|niri|river|wayfire|labwc|mangowm|weston)$ ]]; then
        d --title "Greeter" --menu "Choose a display manager / greeter:" 12 66 3 \
            "ly"       "ly — minimal TUI display manager (recommended)" \
            "tuigreet" "tuigreet — greetd TUI greeter" \
            "gtkgreet" "gtkgreet — greetd GTK greeter, Wayland-native"
        GREETER=$(result)
    fi

    # ── Custom USE flags ──
    d --title "Custom USE Flags" --inputbox \
"Add any extra USE flags (space-separated).
Leave blank for none.

These are appended after the auto-generated flags.
Example: -pulseaudio nls offensive" \
12 66 ""
    CUSTOM_USE=$(result)

    # ── Bootloader ──
    if [[ "$SYS_FIRMWARE" == "uefi" ]]; then
        d --title "Bootloader" --menu "Choose a bootloader:" 18 74 6 \
            "grub"         "GRUB — universal, supports all setups (recommended)" \
            "systemd-boot" "systemd-boot — minimal, fast, UEFI only" \
            "refind"       "rEFInd — graphical, auto-detects kernels, UEFI only" \
            "limine"       "Limine — modern, minimal config, UEFI + BIOS" \
            "uki"          "UKI — single .efi image, no bootloader needed, UEFI only" \
            "libreboot"    "Libreboot — GRUB already in firmware, only generate grub.cfg"
        BOOTLOADER=$(result)
        if [[ "$BOOTLOADER" == "uki" ]]; then
            d --title "UKI Info" --msgbox \
"Unified Kernel Image (UKI) bundles the kernel, initramfs, and
kernel cmdline into a single signed .efi file.

It is booted directly by the EFI firmware — no bootloader layer.
efibootmgr will register it as the default boot entry.

Requires genkernel (forced on)." 12 62
        fi
    else
        d --title "Bootloader" --menu "Choose a bootloader:" 12 72 3 \
            "grub"      "GRUB — standard, well-tested (recommended)" \
            "limine"    "Limine — modern, minimal config" \
            "libreboot" "Libreboot — GRUB already in firmware, only generate grub.cfg"
        BOOTLOADER=$(result)
