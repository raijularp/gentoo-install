    fi

    # Write Wayland session entry so ly can find the compositor
    local session_dir="$MOUNT_ROOT/usr/share/wayland-sessions"
    mkdir -p "$session_dir"
    if [[ "$RAIJU_COMPOSITOR" == "niri" ]]; then
        cat > "$session_dir/niri.desktop" <<'DESK'
