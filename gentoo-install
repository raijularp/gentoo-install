    elif [[ "$RAIJU_COMPOSITOR" == "mangowm" ]]; then
        mkdir -p "$home/.config/mango"
        cat > "$home/.config/mango/config.conf" <<'MANGO'
# Raiju — mango config (generated by gentoo-install)

# Autostart
exec-once=qs -c noctalia-shell
exec-once=pipewire
exec-once=wireplumber

# Appearance
border_width=2
active_border_color=0xcba6f7
inactive_border_color=0x313244
gaps_in=4
gaps_out=8
rounding=12

# Input
kb_layout=us
