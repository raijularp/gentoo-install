    d --title "User Account" --inputbox "Enter username for the new user account:" 8 54 ""
    USERNAME=$(result)
    [[ -n "$USERNAME" ]] || USERNAME="user"

    # ── User password ──
    local upw1 upw2
    d --title "User Password" --passwordbox "Enter password for $USERNAME:" 8 50
    upw1=$(result)
    d --title "User Password" --passwordbox "Confirm password for $USERNAME:" 8 50
    upw2=$(result)
    [[ "$upw1" == "$upw2" ]] || die "User passwords do not match."
    [[ -n "$upw1" ]]          || die "User password cannot be empty."
    USER_PASSWORD="$upw1"

    # ── Root password ──
    local pw1 pw2
    d --title "Root Password" --passwordbox "Enter root password:" 8 50
    pw1=$(result)
    d --title "Root Password" --passwordbox "Confirm root password:" 8 50
    pw2=$(result)
    [[ "$pw1" == "$pw2" ]] || die "Root passwords do not match."
    [[ -n "$pw1" ]]         || die "Root password cannot be empty."
    ROOT_PASSWORD="$pw1"

    # ── Summary + confirm ──
    d --title "Confirm Installation" --yesno \
"Installation Summary
────────────────────────────────────
  Disk:        $DISK
  Firmware:    $SYS_FIRMWARE
  libc:        $LIBC
  Filesystem:  $FS_TYPE
  Init system: $INIT_SYSTEM
  Desktop:     $DESKTOP
  X Server:    ${XSERVER:-n/a}
  Audio:       ${AUDIO:-none}
  Greeter:     ${GREETER:-n/a}
  Kernel:      $KERNEL_METHOD
  Bootloader:  $BOOTLOADER
  Timezone:    $TIMEZONE
  Hostname:    $HOSTNAME
  User:        $USERNAME
────────────────────────────────────
  ALL DATA ON $DISK WILL BE DESTROYED.

Proceed with installation?" 22 52
    dialog_ok || exit 0
}

# ─── Phase 0: WiFi ────────────────────────────────────────────────────────────
phase_wifi() {
    # Skip if already online
    if curl -s --max-time 5 https://distfiles.gentoo.org >/dev/null 2>&1; then
        return 0
    fi

    d --title "Network" --yesno \
"No internet connection detected.

Do you want to connect to a WiFi network?" 8 52
    if ! dialog_ok; then
        return 0
    fi

    # List available wireless interfaces and let user pick
    local iface_list=()
    while IFS= read -r i; do
        iface_list+=("$i" "")
    done < <(iw dev 2>/dev/null | awk '/Interface/{print $2}' || true)

    if [[ ${#iface_list[@]} -eq 0 ]]; then
        d --title "WiFi" --msgbox "No wireless interface found.\nConnect via ethernet and re-run the script." 8 56
        return 0
    fi

    local iface
    if [[ ${#iface_list[@]} -eq 2 ]]; then
        # Only one interface — use it directly
        iface="${iface_list[0]}"
    else
        d --title "WiFi — Interface" --menu "Select your wireless interface:" 12 50 6 "${iface_list[@]}"
        iface=$(result)
    fi
    [[ -z "$iface" ]] && return 0

    # Scan for networks
    info_box "Scanning for WiFi networks on $iface..."
    ip link set "$iface" up 2>/dev/null || true
    local scan_out
    scan_out=$(iw dev "$iface" scan 2>/dev/null | grep 'SSID:' | sed 's/.*SSID: //' | grep -v '^$' | sort -u || true)

    local ssid
    if [[ -n "$scan_out" ]]; then
        local ssid_args=()
        while IFS= read -r s; do
            ssid_args+=("$s" "")
        done <<< "$scan_out"
        ssid_args+=("__manual__" "Enter SSID manually")
        d --title "WiFi — Select Network" --menu "Choose a network:" 20 60 12 "${ssid_args[@]}"
        ssid=$(result)
    fi

    if [[ -z "$ssid" || "$ssid" == "__manual__" ]]; then
        d --title "WiFi — SSID" --inputbox "Enter WiFi network name (SSID):" 8 54 ""
        ssid=$(result)
    fi
    [[ -z "$ssid" ]] && return 0

    d --title "WiFi — Password" --passwordbox "Enter password for \"$ssid\":" 8 54
    local psk; psk=$(result)

    info_box "Connecting to $ssid..."
    local wpa_conf; wpa_conf=$(mktemp)
    wpa_passphrase "$ssid" "$psk" > "$wpa_conf"
    # Kill any existing wpa_supplicant
    pkill wpa_supplicant 2>/dev/null || true
    sleep 1
    wpa_supplicant -B -i "$iface" -c "$wpa_conf" -P /tmp/wpa.pid >/dev/null 2>&1
    rm -f "$wpa_conf"

    # Get IP via DHCP
    dhcpcd "$iface" -t 15 -q 2>/dev/null || dhclient "$iface" 2>/dev/null || true

    # Verify
    if curl -s --max-time 10 https://distfiles.gentoo.org >/dev/null 2>&1; then
        d --title "WiFi" --msgbox "Connected to $ssid successfully." 6 48
    else
        d --title "WiFi" --msgbox "Could not verify connection.\nProceeding anyway — installation may fail if offline." 8 58
    fi
}

# ─── Phase 1: Disk ────────────────────────────────────────────────────────────
phase_disk() {
    info_box "Unmounting any existing mounts on $DISK..."
    swapoff -a 2>/dev/null || true
    umount -R "$MOUNT_ROOT" 2>/dev/null || true
    for part in $(lsblk -lno NAME "$DISK" | tail -n +2); do
        umount -l "/dev/$part" 2>/dev/null || true
    done

    info_box "Partitioning $DISK..."
    [[ "$DISK" =~ nvme ]] && PART_PREFIX="${DISK}p" || PART_PREFIX="${DISK}"

    parted -s "$DISK" mklabel gpt

    if [[ "$FS_TYPE" == "zfs" ]]; then
        if [[ "$SYS_FIRMWARE" == "uefi" ]]; then
            parted -s "$DISK" mkpart ESP fat32 1MiB 513MiB
            parted -s "$DISK" set 1 esp on
            parted -s "$DISK" mkpart boot ext4 513MiB 1537MiB
            parted -s "$DISK" mkpart swap linux-swap 1537MiB 5633MiB
            parted -s "$DISK" mkpart root zfs 5633MiB 100%
            PART_EFI="${PART_PREFIX}1"; PART_BOOT="${PART_PREFIX}2"
            PART_SWAP="${PART_PREFIX}3"; PART_ROOT="${PART_PREFIX}4"
        else
            parted -s "$DISK" mkpart bios_grub 1MiB 3MiB
            parted -s "$DISK" set 1 bios_grub on
            parted -s "$DISK" mkpart boot ext4 3MiB 1027MiB
            parted -s "$DISK" mkpart swap linux-swap 1027MiB 5123MiB
            parted -s "$DISK" mkpart root zfs 5123MiB 100%
            PART_EFI=""; PART_BOOT="${PART_PREFIX}2"
            PART_SWAP="${PART_PREFIX}3"; PART_ROOT="${PART_PREFIX}4"
        fi
    elif [[ "$SYS_FIRMWARE" == "uefi" ]]; then
        parted -s "$DISK" mkpart ESP fat32 1MiB 513MiB
        parted -s "$DISK" set 1 esp on
        parted -s "$DISK" mkpart swap linux-swap 513MiB 4609MiB
        parted -s "$DISK" mkpart root "$FS_TYPE" 4609MiB 100%
        PART_EFI="${PART_PREFIX}1"; PART_SWAP="${PART_PREFIX}2"
        PART_ROOT="${PART_PREFIX}3"; PART_BOOT=""
    else
        parted -s "$DISK" mkpart bios_grub 1MiB 3MiB
        parted -s "$DISK" set 1 bios_grub on
        parted -s "$DISK" mkpart swap linux-swap 3MiB 4099MiB
        parted -s "$DISK" mkpart root "$FS_TYPE" 4099MiB 100%
        PART_SWAP="${PART_PREFIX}2"; PART_ROOT="${PART_PREFIX}3"
        PART_EFI=""; PART_BOOT=""
    fi

    # Ensure filesystem tools are available (minimal ISO may be missing some)
    case "$FS_TYPE" in
        xfs)   command -v mkfs.xfs   &>/dev/null || { info_box "Installing xfsprogs...";   emerge -q sys-fs/xfsprogs;   } ;;
        btrfs) command -v mkfs.btrfs &>/dev/null || { info_box "Installing btrfs-progs..."; emerge -q sys-fs/btrfs-progs; } ;;
        zfs)   command -v zpool      &>/dev/null || { info_box "Installing ZFS tools...";   emerge -q sys-fs/zfs;        } ;;
    esac

    info_box "Formatting partitions..."
    if [[ -n "$PART_EFI"  ]]; then mkfs.vfat -F32 "$PART_EFI"; fi
    if [[ -n "$PART_BOOT" ]]; then mkfs.ext4 -F -L boot "$PART_BOOT"; fi
    mkswap "$PART_SWAP"
    swapon "$PART_SWAP"

    case "$FS_TYPE" in
        ext4)  mkfs.ext4  -F -L root "$PART_ROOT" ;;
        btrfs)
            mkfs.btrfs -f -L root "$PART_ROOT"
            mount "$PART_ROOT" "$MOUNT_ROOT"
            btrfs subvolume create "$MOUNT_ROOT/@"
            btrfs subvolume create "$MOUNT_ROOT/@home"
            btrfs subvolume create "$MOUNT_ROOT/@var_log"
            # @snapshots is NOT pre-created — snapper create-config makes it
            umount "$MOUNT_ROOT"
            ;;
        xfs)   mkfs.xfs   -f -L root "$PART_ROOT" ;;
        zfs)
            zpool destroy rpool 2>/dev/null || true
            zpool create -f \
                -o ashift=12 \
                -O acltype=posixacl -O compression=lz4 -O dnodesize=auto \
                -O normalization=formD -O relatime=on -O xattr=sa \
                -O mountpoint=none rpool "$PART_ROOT"
            zfs create -o mountpoint=/ rpool/root
            zfs create -o mountpoint=/home rpool/home
            zfs create -o mountpoint=/var/log rpool/log
            zpool export rpool
            ;;
    esac

    info_box "Mounting filesystems..."
    mkdir -p "$MOUNT_ROOT"
    if [[ "$FS_TYPE" == "zfs" ]]; then
        zpool import -d "/dev/disk/by-id" -R "$MOUNT_ROOT" rpool
        zfs mount rpool/root
        zfs mount rpool/home
        zfs mount rpool/log
    elif [[ "$FS_TYPE" == "btrfs" ]]; then
        mount -o compress=zstd,noatime,subvol=@ "$PART_ROOT" "$MOUNT_ROOT"
        mkdir -p "$MOUNT_ROOT"/{home,var/log}
        mount -o compress=zstd,noatime,subvol=@home    "$PART_ROOT" "$MOUNT_ROOT/home"
        mount -o compress=zstd,noatime,subvol=@var_log "$PART_ROOT" "$MOUNT_ROOT/var/log"
    else
        mount "$PART_ROOT" "$MOUNT_ROOT"
    fi
    if [[ -n "$PART_BOOT" ]]; then
        mkdir -p "$MOUNT_ROOT/boot"
        mount "$PART_BOOT" "$MOUNT_ROOT/boot"
    fi
    if [[ -n "$PART_EFI" ]]; then
        mkdir -p "$MOUNT_ROOT/boot/efi"
        mount "$PART_EFI" "$MOUNT_ROOT/boot/efi"
    fi
}

# ─── Phase 2: Stage3 ──────────────────────────────────────────────────────────
phase_stage3() {
    info_box "Fetching latest stage3 URL..."

    # Gentoo only ships stage3s for openrc and systemd.
    # runit/s6/dinit use the openrc stage3 as base; the init is swapped post-install.
    local stage3_variant stage3_dir
    if [[ "$LIBC" == "musl" ]]; then
        case "$INIT_SYSTEM" in
            systemd) stage3_variant="amd64-musl-systemd"; stage3_dir="current-stage3-amd64-musl-systemd" ;;
            *)       stage3_variant="amd64-musl";         stage3_dir="current-stage3-amd64-musl" ;;
        esac
    else
        case "$INIT_SYSTEM" in
            systemd) stage3_variant="amd64-systemd"; stage3_dir="current-stage3-amd64-systemd" ;;
            *)       stage3_variant="amd64-openrc";  stage3_dir="current-stage3-amd64-openrc" ;;
        esac
    fi

    local latest_url="${STAGE3_MIRROR}/${stage3_dir}/latest-stage3-${stage3_variant}.txt"
    local stage3_file
    stage3_file=$(curl -s "$latest_url" \
        | grep -v '^#' | grep -v '^-' | grep '\.tar\.' | awk '{print $1}' | head -1)
    [[ -n "$stage3_file" ]] || die "Failed to fetch stage3 URL for ${INIT_SYSTEM}."

    local stage3_url="${STAGE3_MIRROR}/${stage3_dir}/${stage3_file}"
    info_box "Downloading $stage3_file\n(this may take several minutes...)"
    cd "$MOUNT_ROOT"
    curl -L -O "${stage3_url}"
    curl -L -O "${stage3_url}.sha256"
    curl -L -O "${stage3_url}.asc"

    info_box "Verifying checksum..."
    sha256sum -c "${stage3_file}.sha256" || die "Stage3 checksum verification failed."

    info_box "Extracting stage3..."
    tar xpf "$stage3_file" --xattrs-include='*.*' --numeric-owner
    rm -f "$stage3_file" "${stage3_file}.sha256" "${stage3_file}.asc"
    cd /
}

# ─── Phase 3: Portage ─────────────────────────────────────────────────────────
phase_portage() {
    info_box "Configuring make.conf..."

    local cpu_count march use_flags
    cpu_count=$(nproc)
    march=$(gcc -march=native -Q --help=target 2>/dev/null | grep '^\s*-march=' | awk '{print $2}' || echo "native")

    use_flags="-bluetooth"
    if [[ "$DESKTOP" =~ ^(sway|hyprland|niri|river|wayfire|labwc|mangowm|weston)$ ]]; then
        use_flags="wayland $use_flags"
    elif [[ "$DESKTOP" != "none" ]]; then
        use_flags="X alsa $use_flags"
    fi
    case "$AUDIO" in
        pipewire)   use_flags="$use_flags pipewire" ;;
        pulseaudio) use_flags="$use_flags pulseaudio" ;;
    esac
    case "$DESKTOP" in
        kde)     use_flags="$use_flags kde plasma" ;;
        gnome)   use_flags="$use_flags gnome" ;;
        xfce)    use_flags="$use_flags xfce gtk" ;;
        wayfire) use_flags="$use_flags gtk opengl" ;;
        *)       if [[ "$DESKTOP" != "none" ]]; then use_flags="$use_flags gtk"; fi ;;
    esac

    cat > "$MOUNT_ROOT/etc/portage/make.conf" <<EOF
# make.conf — generated by gentoo-install (vibecoded by Claude Code)
COMMON_FLAGS="-march=${march} -O2 -pipe"
CFLAGS="\${COMMON_FLAGS}"
CXXFLAGS="\${COMMON_FLAGS}"
FCFLAGS="\${COMMON_FLAGS}"
FFLAGS="\${COMMON_FLAGS}"

MAKEOPTS="-j${cpu_count}"
EMERGE_DEFAULT_OPTS="--jobs=${cpu_count} --load-average=${cpu_count}"

USE="${use_flags}${CUSTOM_USE:+ $CUSTOM_USE}"

VIDEO_CARDS="intel amdgpu radeon nouveau"
INPUT_DEVICES="libinput"

ACCEPT_LICENSE="*"
ACCEPT_KEYWORDS="~amd64"

GENTOO_MIRRORS="https://distfiles.gentoo.org"
EOF

    cp --dereference /etc/resolv.conf "$MOUNT_ROOT/etc/"
}

# ─── Phase 4: Chroot ──────────────────────────────────────────────────────────
phase_chroot() {
    info_box "Mounting virtual filesystems..."
    mount --types proc  /proc "$MOUNT_ROOT/proc"
    mount --rbind        /sys  "$MOUNT_ROOT/sys"
    mount --make-rslave        "$MOUNT_ROOT/sys"
    mount --rbind        /dev  "$MOUNT_ROOT/dev"
    mount --make-rslave        "$MOUNT_ROOT/dev"
    mount --bind         /run  "$MOUNT_ROOT/run" 2>/dev/null || true

    local fstab_efi="" fstab_boot="" root_uuid=""
    if [[ "$SYS_FIRMWARE" == "uefi" && -n "$PART_EFI" ]]; then
        local efi_uuid; efi_uuid=$(blkid -s UUID -o value "$PART_EFI")
        fstab_efi="UUID=${efi_uuid}  /boot/efi  vfat  defaults  0 2"
    fi
    if [[ -n "$PART_BOOT" ]]; then
        local boot_uuid; boot_uuid=$(blkid -s UUID -o value "$PART_BOOT")
        fstab_boot="UUID=${boot_uuid}  /boot  ext4  defaults,noatime  0 2"
    fi
    if [[ "$FS_TYPE" != "zfs" ]]; then root_uuid=$(blkid -s UUID -o value "$PART_ROOT"); fi
    local swap_uuid; swap_uuid=$(blkid -s UUID -o value "$PART_SWAP")

    local grub_target
    [[ "$SYS_FIRMWARE" == "uefi" ]] \
        && grub_target="--target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Gentoo" \
        || grub_target="--target=i386-pc $DISK"

    local WAYLAND_BASE="sys-auth/seatd x11-terms/alacritty gui-apps/waybar gui-apps/wofi"
    local desktop_pkgs=""
    case "$DESKTOP" in
        kde)      desktop_pkgs="kde-plasma/plasma-meta kde-apps/kde-apps-meta x11-base/xorg-server" ;;
        gnome)    desktop_pkgs="gnome-base/gnome x11-base/xorg-server" ;;
        xfce)     desktop_pkgs="xfce-base/xfce4-meta x11-base/xorg-server" ;;
        i3)       desktop_pkgs="x11-wm/i3 x11-misc/i3status x11-misc/dmenu x11-terms/alacritty x11-base/xorg-server" ;;
        openbox)  desktop_pkgs="x11-wm/openbox x11-misc/tint2 x11-misc/dmenu x11-terms/alacritty x11-base/xorg-server" ;;
        bspwm)    desktop_pkgs="x11-wm/bspwm x11-misc/sxhkd x11-misc/dmenu x11-terms/alacritty x11-base/xorg-server" ;;
        dwm)      desktop_pkgs="x11-wm/dwm x11-terms/st x11-base/xorg-server" ;;
        sway)     desktop_pkgs="gui-wm/sway $WAYLAND_BASE" ;;
        hyprland) desktop_pkgs="gui-wm/hyprland gui-apps/hyprpaper $WAYLAND_BASE" ;;
        niri)     desktop_pkgs="gui-wm/niri $WAYLAND_BASE" ;;
        river)    desktop_pkgs="gui-wm/river $WAYLAND_BASE" ;;
        wayfire)  desktop_pkgs="gui-wm/wayfire gui-wm/wcm $WAYLAND_BASE" ;;
        labwc)    desktop_pkgs="gui-wm/labwc $WAYLAND_BASE" ;;
        mangowm)  desktop_pkgs="gui-wm/mangowm gui-libs/scenefx gui-apps/grim gui-apps/slurp $WAYLAND_BASE" ;;
        weston)   desktop_pkgs="gui-libs/weston x11-terms/alacritty sys-auth/seatd" ;;
    esac

    local dm_pkg="" dm_service=""
    case "$DESKTOP" in
        kde)   dm_pkg="x11-misc/sddm";  dm_service="sddm" ;;
        gnome) dm_pkg="gnome-base/gdm"; dm_service="gdm" ;;
        xfce|i3|openbox|bspwm|dwm)
            case "$GREETER" in
                slick) dm_pkg="x11-misc/lightdm x11-misc/lightdm-slick-greeter" ;;
                *)     dm_pkg="x11-misc/lightdm x11-misc/lightdm-gtk-greeter" ;;
            esac
            dm_service="lightdm"
            ;;
        sway|hyprland|niri|river|wayfire|labwc|mangowm|weston)
            case "$GREETER" in
                ly)       dm_pkg="x11-misc/ly";                               dm_service="ly" ;;
                gtkgreet) dm_pkg="gui-apps/greetd gui-apps/gtkgreet";         dm_service="greetd" ;;
                *)        dm_pkg="gui-apps/greetd gui-apps/tuigreet";         dm_service="greetd" ;;
            esac
            ;;
    esac

    local audio_pkgs=""
    case "$AUDIO" in
        pipewire)   audio_pkgs="media-video/pipewire media-sound/wireplumber" ;;
        pulseaudio) audio_pkgs="media-sound/pulseaudio" ;;
    esac

    info_box "Writing chroot setup script..."
    cat > "$MOUNT_ROOT/setup-chroot.sh" <<'CHROOT_SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

trap 'echo "[chroot] FAILED at line $LINENO: $BASH_COMMAND" >&2' ERR

echo "[chroot] Syncing Portage tree..."
emerge-webrsync -q || { echo "[chroot] emerge-webrsync failed, retrying with emerge --sync..."; emerge --sync -q; }

echo "[chroot] Selecting profile..."
if [[ "${LIBC}" == "musl" ]]; then
    eselect profile set default/linux/amd64/23.0/musl
else
    case "${INIT_SYSTEM}" in
        systemd) eselect profile set default/linux/amd64/23.0/systemd ;;
        *)       eselect profile set default/linux/amd64/23.0 ;;
    esac
fi

echo "[chroot] Installing init system..."
case "${INIT_SYSTEM}" in
    openrc|systemd)
        # Already in the stage3 — nothing to do
        ;;
    runit)
        emerge -q sys-process/runit
        rc-update -a del 2>/dev/null || true
        ;;
    s6)
        emerge -q sys-apps/s6 sys-apps/s6-rc sys-apps/s6-linux-init
        rc-update -a del 2>/dev/null || true
        ;;
    dinit)
        emerge -q sys-apps/dinit
        rc-update -a del 2>/dev/null || true
        ;;
esac

echo "[chroot] Setting timezone..."
# Case-insensitive match against actual zoneinfo files
_tz_match=$(find /usr/share/zoneinfo -type f | sed 's|/usr/share/zoneinfo/||' | grep -ix "${TIMEZONE}" | head -1 || true)
if [[ -n "$_tz_match" ]]; then TIMEZONE="$_tz_match"; fi
echo "${TIMEZONE}" > /etc/timezone
ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime

echo "[chroot] Setting locale..."
echo "${LOCALE} UTF-8" >> /etc/locale.gen
locale-gen
_locale_sel=$(locale -a 2>/dev/null | grep -i "${LOCALE%%.*}" | head -1 || true)
if [[ -n "$_locale_sel" ]]; then eselect locale set "$_locale_sel"; fi
env-update
source /etc/profile 2>/dev/null || true

echo "[chroot] Installing kernel sources..."
emerge -q sys-kernel/gentoo-sources sys-kernel/linux-firmware
eselect kernel set 1

if [[ "${FS_TYPE}" == "zfs" ]]; then
    echo "[chroot] Installing ZFS..."
    emerge -q sys-fs/zfs sys-fs/zfs-kmod
    zgenhostid
    case "${INIT_SYSTEM}" in
        openrc)
            rc-update add zfs-import boot
            rc-update add zfs-mount boot
            rc-update add zfs-share default
            ;;
        systemd)
            systemctl enable zfs-import-cache zfs-import.target zfs-mount zfs-share zfs.target
            ;;
        runit)
            for svc in zfs-import zfs-mount; do
                mkdir -p /etc/sv/${svc}
                printf '#!/bin/sh\nexec %s\n' "${svc}" > /etc/sv/${svc}/run
                chmod +x /etc/sv/${svc}/run
                ln -sf /etc/sv/${svc} /etc/service/${svc}
            done
            ;;
        s6)
            for svc in zfs-import zfs-mount; do
                mkdir -p /etc/s6/adminsv/${svc}
                printf 'longrun' > /etc/s6/adminsv/${svc}/type
                printf '#!/bin/execlineb -P\n%s\n' "${svc}" > /etc/s6/adminsv/${svc}/run
                chmod +x /etc/s6/adminsv/${svc}/run
                ln -sf /etc/s6/adminsv/${svc} /etc/s6/adminsv/default/contents.d/${svc}
            done
            ;;
        dinit)
            mkdir -p /etc/dinit.d/boot.d
            for svc in zfs-import zfs-mount; do
                [[ -f /etc/dinit.d/${svc} ]] && \
                    ln -sf /etc/dinit.d/${svc} /etc/dinit.d/boot.d/${svc} || true
            done
            ;;
    esac
fi

if [[ "${KERNEL_METHOD}" == "genkernel" || "${FS_TYPE}" == "zfs" ]]; then
    emerge -q sys-kernel/genkernel
    if [[ "${FS_TYPE}" == "zfs" ]]; then
        genkernel --zfs all
    else
        genkernel all
    fi
elif [[ "${KERNEL_METHOD}" == "manual" ]]; then
    echo "[chroot] Kernel sources at /usr/src/linux — compile manually post-install."
fi

echo "[chroot] Writing fstab..."
if [[ "${FS_TYPE}" == "zfs" ]]; then
    cat > /etc/fstab <<FSTAB
# ZFS datasets are mounted by the initramfs — no root entry needed
UUID=${swap_uuid}  none  swap  sw  0 0
${fstab_boot}
${fstab_efi}
FSTAB
elif [[ "${FS_TYPE}" == "btrfs" ]]; then
    cat > /etc/fstab <<FSTAB
UUID=${root_uuid}  /         btrfs  compress=zstd,noatime,subvol=@        0 0
UUID=${root_uuid}  /home     btrfs  compress=zstd,noatime,subvol=@home    0 0
UUID=${root_uuid}  /var/log  btrfs  compress=zstd,noatime,subvol=@var_log 0 0
UUID=${swap_uuid}  none      swap   sw                                     0 0
${fstab_boot}
${fstab_efi}
FSTAB
else
    cat > /etc/fstab <<FSTAB
UUID=${root_uuid}  /     ${FS_TYPE}  defaults,noatime  0 1
UUID=${swap_uuid}  none  swap        sw                0 0
${fstab_boot}
${fstab_efi}
FSTAB
fi

echo "[chroot] Setting hostname..."
echo "${HOSTNAME}" > /etc/hostname

echo "[chroot] Configuring network (NetworkManager)..."
emerge -q net-misc/networkmanager

case "${INIT_SYSTEM}" in
    openrc)
        rc-update add NetworkManager default
        ;;
    systemd)
        systemctl enable NetworkManager
        ;;
    runit)
        mkdir -p /etc/sv/NetworkManager /etc/service
        cat > /etc/sv/NetworkManager/run <<'RUN'
#!/bin/sh
exec NetworkManager --no-daemon
RUN
        chmod +x /etc/sv/NetworkManager/run
        ln -sf /etc/sv/NetworkManager /etc/service/NetworkManager
        ;;
    s6)
        mkdir -p /etc/s6/adminsv/NetworkManager /etc/s6/adminsv/default/contents.d
        printf 'longrun' > /etc/s6/adminsv/NetworkManager/type
        cat > /etc/s6/adminsv/NetworkManager/run <<'RUN'
#!/bin/execlineb -P
NetworkManager --no-daemon
RUN
        chmod +x /etc/s6/adminsv/NetworkManager/run
        ln -sf /etc/s6/adminsv/NetworkManager /etc/s6/adminsv/default/contents.d/NetworkManager
        ;;
    dinit)
        cat > /etc/dinit.d/NetworkManager <<'DSVC'
type = process
command = /usr/sbin/NetworkManager --no-daemon
depends-on = local.target
DSVC
        mkdir -p /etc/dinit.d/boot.d
        ln -sf /etc/dinit.d/NetworkManager /etc/dinit.d/boot.d/NetworkManager
        ;;
esac

echo "[chroot] Setting root password..."
echo "root:${ROOT_PASSWORD}" | chpasswd

echo "[chroot] Creating user ${USERNAME}..."
useradd -m -G wheel,audio,video,input -s /bin/bash "${USERNAME}"
echo "${USERNAME}:${USER_PASSWORD}" | chpasswd
emerge -q app-admin/doas
echo "permit persist :wheel" > /etc/doas.conf
chmod 600 /etc/doas.conf

echo "[chroot] Installing base system tools..."
emerge -q app-admin/sysklogd sys-process/cronie sys-apps/mlocate net-misc/ntp app-editors/vim

case "${INIT_SYSTEM}" in
    openrc)
        rc-update add sysklogd default
        rc-update add cronie default
        rc-update add ntpd default
        ;;
    systemd)
        systemctl enable cronie ntpd
        ;;
    runit)
        # Write run scripts for each service — stage3 doesn't ship them
        for svc in sysklogd cronie ntpd; do
            mkdir -p /etc/sv/${svc}
        done
        cat > /etc/sv/sysklogd/run <<'RUN'
#!/bin/sh
exec syslogd -n
RUN
        cat > /etc/sv/cronie/run <<'RUN'
#!/bin/sh
exec crond -n
RUN
        cat > /etc/sv/ntpd/run <<'RUN'
#!/bin/sh
exec ntpd -n -g
RUN
        for svc in sysklogd cronie ntpd; do
            chmod +x /etc/sv/${svc}/run
            ln -sf /etc/sv/${svc} /etc/service/${svc}
        done
        ;;
    s6)
        declare -A _s6cmd=([sysklogd]="syslogd -n" [cronie]="crond -n" [ntpd]="ntpd -n -g")
        for svc in sysklogd cronie ntpd; do
            mkdir -p /etc/s6/adminsv/${svc}
            printf 'longrun' > /etc/s6/adminsv/${svc}/type
            printf '#!/bin/execlineb -P\n%s\n' "${_s6cmd[$svc]}" > /etc/s6/adminsv/${svc}/run
            chmod +x /etc/s6/adminsv/${svc}/run
            ln -sf /etc/s6/adminsv/${svc} /etc/s6/adminsv/default/contents.d/${svc}
        done
        ;;
    dinit)
        # Write service files — these packages may not ship dinit units
        cat > /etc/dinit.d/sysklogd <<'DSVC'
type = process
command = /sbin/syslogd -n
depends-on = local.target
DSVC
        cat > /etc/dinit.d/cronie <<'DSVC'
type = process
command = /usr/sbin/crond -n
depends-on = local.target
DSVC
        cat > /etc/dinit.d/ntpd <<'DSVC'
type = process
command = /usr/sbin/ntpd -n -g
depends-on = local.target
DSVC
        mkdir -p /etc/dinit.d/boot.d
        for svc in sysklogd cronie ntpd; do
            ln -sf /etc/dinit.d/${svc} /etc/dinit.d/boot.d/${svc}
        done
        ;;
esac

if [[ "${FS_TYPE}" == "btrfs" ]]; then
    echo "[chroot] Installing snapper..."
    emerge -q app-backup/snapper
    # snapper creates its own .snapshots subvolume — don't pre-create it
    snapper --no-dbus -c root create-config /
    # Set snapshot limits
    sed -i 's/^TIMELINE_LIMIT_HOURLY=.*/TIMELINE_LIMIT_HOURLY="5"/'   /etc/snapper/configs/root
    sed -i 's/^TIMELINE_LIMIT_DAILY=.*/TIMELINE_LIMIT_DAILY="7"/'     /etc/snapper/configs/root
    sed -i 's/^TIMELINE_LIMIT_WEEKLY=.*/TIMELINE_LIMIT_WEEKLY="4"/'   /etc/snapper/configs/root
    sed -i 's/^TIMELINE_LIMIT_MONTHLY=.*/TIMELINE_LIMIT_MONTHLY="6"/' /etc/snapper/configs/root
    sed -i 's/^TIMELINE_LIMIT_YEARLY=.*/TIMELINE_LIMIT_YEARLY="2"/'   /etc/snapper/configs/root
    # Add .snapshots to fstab now that snapper has created the subvolume
    snap_uuid=$(findmnt -no UUID /)
    echo "UUID=${snap_uuid}  /.snapshots  btrfs  compress=zstd,noatime,subvol=@/.snapshots  0 0" >> /etc/fstab
    case "${INIT_SYSTEM}" in
        openrc)  rc-update add snapper-timeline default; rc-update add snapper-cleanup default ;;
        systemd) systemctl enable snapper-timeline.timer snapper-cleanup.timer ;;
    esac
fi

echo "[chroot] Installing bootloader (${BOOTLOADER})..."

# Build root options string used by several bootloaders
_root_opts="root=UUID=${root_uuid} rw quiet"
if [[ "${FS_TYPE}" == "btrfs" ]]; then _root_opts="${_root_opts} rootflags=subvol=@"; fi
if [[ "${FS_TYPE}" == "zfs"   ]]; then _root_opts="root=ZFS=rpool/root rw"; fi

# Locate kernel + initramfs written by genkernel (used by several bootloaders)
_kern=$(find /boot -maxdepth 1 -name 'vmlinuz-*' 2>/dev/null | sort -V | tail -1 || true)
_init=$(find /boot -maxdepth 1 -name 'initramfs-*' 2>/dev/null | sort -V | tail -1 || true)
_kern_rel="${_kern#/boot/}"
_init_rel="${_init#/boot/}"

case "${BOOTLOADER}" in
    grub)
        mkdir -p /etc/portage/package.use
        if [[ "${SYS_FIRMWARE}" == "uefi" ]]; then
            echo "sys-boot/grub:2 grub_platforms_efi-64" >> /etc/portage/package.use/grub
        else
            echo "sys-boot/grub:2 grub_platforms_pc" >> /etc/portage/package.use/grub
        fi
        emerge -q sys-boot/grub
        grub-install ${grub_target}
        grub-mkconfig -o /boot/grub/grub.cfg
        ;;

    systemd-boot)
        emerge -q sys-apps/systemd-utils
        bootctl install --esp-path=/boot/efi
        mkdir -p /boot/efi/loader/entries
        cat > /boot/efi/loader/loader.conf <<LDRCONF
default gentoo.conf
timeout 4
console-mode max
editor no
LDRCONF
        cat > /boot/efi/loader/entries/gentoo.conf <<ENTRY
title   Gentoo Linux
linux   /${_kern_rel}
initrd  /${_init_rel}
options ${_root_opts}
ENTRY
        ;;

    refind)
        emerge -q sys-boot/refind
        refind-install
        echo "\"Boot\" \"${_root_opts}\"" > /boot/refind_linux.conf
        ;;

    limine)
        emerge -q sys-boot/limine
        mkdir -p /boot/limine
        cat > /boot/limine/limine.conf <<LIMCFG
timeout: 5

/Gentoo Linux
    protocol: linux
    kernel_path: boot():/vmlinuz-${_kern_rel#vmlinuz-}
    module_path: boot():/initramfs-${_init_rel#initramfs-}
    cmdline: ${_root_opts}
LIMCFG
        if [[ "${SYS_FIRMWARE}" == "uefi" ]]; then
            mkdir -p /boot/efi/EFI/LIMINE
            cp /usr/share/limine/BOOTX64.EFI /boot/efi/EFI/LIMINE/
            cp /usr/share/limine/limine.sys  /boot/limine/ 2>/dev/null || true
        else
            limine bios-install "${DISK}"
            cp /usr/share/limine/limine.sys /boot/limine/
        fi
        ;;

    uki)
        # Unified Kernel Image — single .efi, booted directly by firmware
        mkdir -p /etc/portage/package.use
        echo "sys-apps/systemd-utils boot" >> /etc/portage/package.use/systemd-utils
        emerge -q sys-apps/systemd-utils sys-boot/efibootmgr
        mkdir -p /boot/efi/EFI/Linux
        ukify build \
            --linux="${_kern}" \
            --initrd="${_init}" \
            --cmdline="${_root_opts}" \
            --output=/boot/efi/EFI/Linux/gentoo.efi
        # Register as default EFI boot entry
        _esp_dev=$(findmnt -no SOURCE /boot/efi)
        _esp_part_num=$(cat /sys/class/block/${_esp_dev##*/}/partition 2>/dev/null || echo 1)
        efibootmgr -c -d "${DISK}" -p "${_esp_part_num}" \
            -l '\EFI\Linux\gentoo.efi' -L "Gentoo Linux"
        ;;

    libreboot)
        # Libreboot ships GRUB as a firmware payload — no grub-install needed.
        # Install GRUB tools for grub-mkconfig, then generate the config only.
        mkdir -p /etc/portage/package.use
        echo "sys-boot/grub:2 grub_platforms_pc" >> /etc/portage/package.use/grub
        emerge -q sys-boot/grub
        mkdir -p /boot/grub
        grub-mkconfig -o /boot/grub/grub.cfg
        ;;
esac

# Install / swap X11 server if requested
case "${XSERVER}" in
    xorg)
        echo "[chroot] Installing Xorg..."
        emerge -q x11-base/xorg-server x11-base/xorg-drivers
        ;;
    xlibre)
        echo "[chroot] Installing XLibre (community Xorg fork)..."
        emerge -q app-eselect/eselect-repository dev-vcs/git
        eselect repository enable xlibre
        emaint sync -r xlibre
        echo "*/*::xlibre ~amd64" > /etc/portage/package.accept_keywords/xlibre
        # Fetch first, remove xorg-server if present, then install xlibre
        emerge -f x11-base/xlibre-server
        emerge -C x11-base/xorg-server x11-base/xorg-drivers 2>/dev/null || true
        emerge -q x11-base/xlibre-server
        emerge -q @x11-module-rebuild @preserved-rebuild 2>/dev/null || true
        ;;
    wayland)
        echo "[chroot] Installing Wayland libraries..."
        emerge -q dev-libs/wayland dev-libs/wayland-protocols
        ;;
esac

if [[ -n "${desktop_pkgs}" ]]; then
    echo "[chroot] Installing desktop environment (this will take a while)..."

    # Enable GURU overlay if needed (mangowm or noctalia)
    if [[ "${DESKTOP}" == "mangowm" || "${RAIJU_MODE}" == "1" ]]; then
        emerge -q app-eselect/eselect-repository dev-vcs/git
        eselect repository enable guru
        emerge --sync guru
    fi

    emerge -q ${desktop_pkgs} ${dm_pkg}

    if [[ "${RAIJU_MODE}" == "1" ]]; then
        echo "[chroot] Installing Noctalia Shell and dependencies..."
        emerge -q gui-apps/noctalia-shell \
            media-gfx/imagemagick \
            sys-power/brightnessctl \
            media-video/ffmpeg \
            dev-qt/qt6-multimedia \
            dev-python/setuptools \
            gui-apps/wlr-randr \
            gui-apps/cliphist \
            gui-apps/wlsunset
    fi

    if [[ -n "${dm_service}" ]]; then
        case "${INIT_SYSTEM}" in
            openrc)  rc-update add ${dm_service} default ;;
            systemd) systemctl enable ${dm_service} ;;
            runit)
                mkdir -p /etc/sv/${dm_service}
                cat > /etc/sv/${dm_service}/run <<RUN
#!/bin/sh
exec ${dm_service}
RUN
                chmod +x /etc/sv/${dm_service}/run
                ln -sf /etc/sv/${dm_service} /etc/service/${dm_service}
                ;;
            s6)
                mkdir -p /etc/s6/adminsv/${dm_service}
                printf 'longrun' > /etc/s6/adminsv/${dm_service}/type
                printf '#!/bin/execlineb -P\n%s\n' "${dm_service}" > /etc/s6/adminsv/${dm_service}/run
                chmod +x /etc/s6/adminsv/${dm_service}/run
                ln -sf /etc/s6/adminsv/${dm_service} /etc/s6/adminsv/default/contents.d/${dm_service}
                ;;
            dinit)
                # Use installed service file if present, else write a minimal one
                if [[ ! -f /etc/dinit.d/${dm_service} ]]; then
                    printf 'type = process\ncommand = /usr/sbin/%s\ndepends-on = local.target\n' \
                        "${dm_service}" > /etc/dinit.d/${dm_service}
                fi
                mkdir -p /etc/dinit.d/boot.d
                ln -sf /etc/dinit.d/${dm_service} /etc/dinit.d/boot.d/${dm_service}
                ;;
        esac
    fi

    echo "[chroot] Installing Firefox..."
    emerge -q www-client/firefox-bin
fi

if [[ -n "${audio_pkgs}" ]]; then
    echo "[chroot] Installing audio server..."
    emerge -q ${audio_pkgs}
    if [[ "${AUDIO}" == "pipewire" ]]; then
        # pipewire is user-session managed; create system-wide config dir
        mkdir -p /etc/pipewire
        cp /usr/share/pipewire/pipewire.conf /etc/pipewire/ 2>/dev/null || true
    fi
fi

# Configure greeter if needed
if [[ "${GREETER}" == "slick" ]]; then
    mkdir -p /etc/lightdm
    cat >> /etc/lightdm/lightdm.conf <<LCONF
[Seat:*]
greeter-session=lightdm-slick-greeter
LCONF
elif [[ "${GREETER}" == "gtkgreet" ]]; then
    mkdir -p /etc/greetd
    cat > /etc/greetd/config.toml <<GCONF
[terminal]
vt = 1
[default_session]
command = "gtkgreet"
user = "greeter"
GCONF
fi

# Compile s6-rc service database after all services have been configured
if [[ "${INIT_SYSTEM}" == "s6" ]]; then
    echo "[chroot] Compiling s6-rc service database..."
    # Source dir is adminsv; compiled db replaces the existing one atomically
    if command -v s6-rc-compile &>/dev/null; then
        s6-rc-compile /etc/s6/rc/compiled.new /etc/s6/adminsv && \
            mv /etc/s6/rc/compiled.new /etc/s6/rc/compiled || \
            echo "[warn] s6-rc-compile failed — service activation may need manual repair post-boot"
    else
        echo "[warn] s6-rc-compile not found — service activation may need manual repair post-boot"
    fi
fi

echo "[chroot] Done!"
CHROOT_SCRIPT

    chmod +x "$MOUNT_ROOT/setup-chroot.sh"

    info_box "Entering chroot — this will take a while...\nDo not close this terminal."
    env -i \
        HOME=/root PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
        TERM=linux DEBUGINFOD_URLS="" DEBUGINFOD_IMA_CERT_PATH="" \
        INIT_SYSTEM="$INIT_SYSTEM" \
        TIMEZONE="$TIMEZONE" \
        LOCALE="$LOCALE" \
        KERNEL_METHOD="$KERNEL_METHOD" \
        HOSTNAME="$HOSTNAME" \
        ROOT_PASSWORD="$ROOT_PASSWORD" \
        SYS_FIRMWARE="$SYS_FIRMWARE" \
        FS_TYPE="$FS_TYPE" \
        DISK="$DISK" \
        DESKTOP="$DESKTOP" \
        AUDIO="$AUDIO" \
        GREETER="$GREETER" \
        RAIJU_MODE="${RAIJU_MODE:-0}" \
        LIBC="$LIBC" \
        root_uuid="$root_uuid" \
        swap_uuid="$swap_uuid" \
        fstab_efi="$fstab_efi" \
        fstab_boot="$fstab_boot" \
        grub_target="$grub_target" \
        desktop_pkgs="$desktop_pkgs" \
        dm_pkg="$dm_pkg" \
        dm_service="$dm_service" \
        audio_pkgs="$audio_pkgs" \
        CUSTOM_USE="${CUSTOM_USE:-}" \
        BOOTLOADER="${BOOTLOADER:-grub}" \
        USERNAME="${USERNAME:-user}" \
        USER_PASSWORD="${USER_PASSWORD:-}" \
        XSERVER="${XSERVER:-}" \
        chroot "$MOUNT_ROOT" /bin/bash /setup-chroot.sh

    rm -f "$MOUNT_ROOT/setup-chroot.sh"
}

# ─── Phase 5: Cleanup ─────────────────────────────────────────────────────────
phase_cleanup() {
    info_box "Unmounting filesystems..."
    umount -l "$MOUNT_ROOT/dev"  2>/dev/null || true
    umount -l "$MOUNT_ROOT/sys"  2>/dev/null || true
    umount -l "$MOUNT_ROOT/proc" 2>/dev/null || true
    umount -R "$MOUNT_ROOT"      2>/dev/null || true
    if [[ "$FS_TYPE" == "zfs" ]]; then
        zfs unmount -a  2>/dev/null || true
        zpool export rpool 2>/dev/null || true
    fi
    swapoff "$PART_SWAP" 2>/dev/null || true
}

# ─── Main ─────────────────────────────────────────────────────────────────────
main() {
    RAIJU_MODE=0
    RAIJU_COMPOSITOR=""
    USERNAME=""
    USER_PASSWORD=""
    XSERVER=""
    collect_config

    clear
    echo "Starting installation — this will take 30–90+ minutes."
    echo "Output will scroll below. Do not close this terminal."
    echo

    phase_wifi
    phase_disk
    phase_stage3
    phase_portage
    phase_chroot
    if [[ "${RAIJU_MODE:-0}" == "1" ]]; then phase_raiju_dotfiles; fi
    phase_cleanup

    local msg="Installation complete!\n\nReboot into your new Gentoo system."
    if [[ "$KERNEL_METHOD" == "manual" ]]; then
        msg+="\n\nManual kernel: chroot back in, compile at /usr/src/linux,\nthen run: grub-mkconfig -o /boot/grub/grub.cfg"
    fi

    d --title "Done!" --yesno "${msg}\n\nReboot now?" 16 58
    dialog_ok && reboot
}

main "$@"
